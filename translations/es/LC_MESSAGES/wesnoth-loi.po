"<span color='green'>Damage increased by 23%</span>\n"
"<span color='green'>70% fewer attacks</span>\n"
"<span color='blue'>Max experience decreased by 4 XP.</span>"
msgstr ""
"<span color='green'>Daño aumentado en 23%</span>\n"
"<span color='green'>70% menos ataques</span>\n"
"<span color='blue'>Experiencia máx. disminuida en 4 XP.</span>"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:6676
msgid "Hardly a week passes that some one does not revive a new cult."
msgstr "Casi no pasa una semana sin que alguien reviva un nuevo culto."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:6688
msgid "I killed many with my mace."
msgstr "Maté a muchos con mi maza."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:6704
msgid ""
"<span color='#60A0FF'>Increases physical resistances by 2%</span>\n"
"<span color='#60A0FF'>Chance to get hit decreased by 10%</span>\n"
"<span color='orange'>Max HP increased by 14 HP.</span>"
msgstr ""
"<span color='#60A0FF'>Aumenta resistencias físicas en 2%</span>\n"
"<span color='#60A0FF'>Chance de ser golpeado disminuida en 10%</span>\n"
"<span color='orange'>PV máx. aumentados en 14 PV.</span>"

