#. [object]
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1690 .\utils\item_list.cfg:11666
msgid "Straight axe of monstrosity"
msgstr "Hacha recta de monstruosidad"

#. [message], speaker=trader
