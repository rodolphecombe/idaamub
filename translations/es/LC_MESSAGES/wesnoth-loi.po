#: Legends_of_Idaamub/utils/item_list.cfg:6722
msgid "The inversion theory has a long and fascinating history."
msgstr "La teoría de inversión tiene una larga y fascinante historia."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:6725
msgid "Unscratched turtle shield"
msgstr "Escudo de tortuga sin rasguños"

