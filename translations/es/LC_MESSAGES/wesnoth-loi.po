msgstr "Tan pesada como una armadura de placas pero un poco más flexible."

#. [object]
#: .\utils\item_list.cfg:13400
msgid "Wonderful crossbow of the punisher"
msgstr "Ballesta maravillosa del castigador"

#. [object]
#: .\utils\item_list.cfg:13409
