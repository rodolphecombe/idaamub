#: .\scenarios\chapter4\23_Abxoowbus_Trading_Post.cfg:1314
#: .\scenarios\chapter4\23_Abxoowbus_Trading_Post.cfg:1350
#: .\scenarios\chapter4\28_Travelers.cfg:1673
#: .\scenarios\chapter4\28_Travelers.cfg:1709
#: .\scenarios\chapter4\28_Travelers.cfg:1745
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1980
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:2016
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:2052
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1914
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1950
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1986
msgid "We now have $food_counter| food."
msgstr "Ahora tenemos $food_counter| comida."

#. [option]
#: .\scenarios\chapter2\06_Zei.cfg:1911 .\scenarios\chapter2\11_Qyizu.cfg:1978
#: .\scenarios\chapter3\17_Udxatfe.cfg:727
#: .\scenarios\chapter4\23_Abxoowbus_Trading_Post.cfg:1293
#: .\scenarios\chapter4\28_Travelers.cfg:1688
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1995
