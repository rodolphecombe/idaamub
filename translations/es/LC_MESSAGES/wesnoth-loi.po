msgstr "Permite reclutar Lobos Temibles"

#. [object]
#: .\utils\item_list.cfg:14973
msgid "Alea jacta est."
msgstr "La suerte está echada."

#. [object]
#: .\utils\item_list.cfg:14976
msgid "Battle-axe"
msgstr "Hacha de batalla"

#. [object]
#: .\utils\item_list.cfg:14986
msgid "For enemies, not trees."
msgstr "Para enemigos, no árboles."

