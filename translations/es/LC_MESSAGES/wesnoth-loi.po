#: .\utils\item_list.cfg:6704
msgid "I killed many with my mace."
msgstr "Maté a muchos con mi maza."

#. [object]
#: .\utils\item_list.cfg:6720
msgid ""
"<span color='#60A0FF'>Increases physical resistances by 2%</span>\n"
"<span color='#60A0FF'>Chance to get hit decreased by 10%</span>\n"
"<span color='orange'>Max HP increased by 14 HP.</span>"
msgstr ""
"<span color='#60A0FF'>Aumenta resistencias físicas en 2%</span>\n"
"<span color='#60A0FF'>Chance de ser golpeado disminuida en 10%</span>\n"
"<span color='orange'>PV máx. aumentados en 14 PV.</span>"

