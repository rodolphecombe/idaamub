#. [option]
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:659
#: .\scenarios\chapter2\09_Spider_Maze.cfg:811
msgid "No, I don't want to know what's behind."
msgstr "No, no quiero saber qué hay detrás."

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:690
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:952
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:996
msgid "Argh! I'm burning! There was a trap."
msgstr "¡Argh! ¡Me quemo! Había una trampa."

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:734
msgid "Argh! I'm burning! The floor is trapped."
msgstr "¡Argh! ¡Me quemo! El piso está atrapado."

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:770
#: .\scenarios\chapter2\08_Inside_Uvju_s_cross.cfg:779
msgid "There are two large wooden doors. Should I try to open them?"
msgstr "Hay dos grandes puertas de madera. ¿Debo intentar abrirlas?"

