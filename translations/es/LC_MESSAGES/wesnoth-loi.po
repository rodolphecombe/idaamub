"<span color='green'>Daño aumentado en 21 %</span>\n"
"<span color='orange'>PV máx. aumentados en 5 PV.</span>\n"
"<span color='blue'>XP máx. aumentados en 4 XP.</span>"

#. [object]
#: .\utils\item_list.cfg:13437
msgid ""
"At length his lonely cot appears in view,\n"
"Beneath the shelter of an aged tree."
msgstr ""
"Al fin su solitaria choza aparece a la vista,\n"
"Bajo el refugio de un árbol antiguo."

#. [object]
#: .\utils\item_list.cfg:13441
msgid "Ripper leather gloves"
msgstr "Guantes de cuero rasgadores"

#. [object]
#: .\utils\item_list.cfg:13449
