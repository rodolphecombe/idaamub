#. [message], speaker=trader
#. [object]
#: .\scenarios\chapter2\06_Zei.cfg:2231 .\utils\item_list.cfg:4425
msgid "Healing hands"
msgstr "Manos sanadoras"

#. [message], speaker=trader
#: .\scenarios\chapter2\06_Zei.cfg:2257 .\scenarios\chapter2\11_Qyizu.cfg:1874
#: .\scenarios\chapter3\17_Udxatfe.cfg:1575
#: .\scenarios\chapter4\23_Abxoowbus_Trading_Post.cfg:1187
#: .\scenarios\chapter4\28_Travelers.cfg:1575
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1887
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1823
