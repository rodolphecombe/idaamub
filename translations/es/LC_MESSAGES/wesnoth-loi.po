#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2196
#: Legends_of_Idaamub/utils/item_list.cfg:6514
msgid "Short bow of awareness"
msgstr "Arco corto de conciencia"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2197
#: Legends_of_Idaamub/utils/item_list.cfg:6588
msgid "Bow of slippery design"
msgstr "Arco de diseño resbaladizo"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2198
