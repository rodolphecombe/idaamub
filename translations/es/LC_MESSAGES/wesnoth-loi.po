#: .\scenarios\chapter6\39_Oofs_Fortress.cfg:516
#: .\scenarios\chapter6\43_Western_Village.cfg:378
msgid "Buy potions"
msgstr "Comprar pociones"

#. [message], speaker=trader
#: .\scenarios\chapter2\06_Zei.cfg:2224 .\scenarios\chapter2\11_Qyizu.cfg:1843
#: .\scenarios\chapter3\17_Udxatfe.cfg:1544
#: .\scenarios\chapter4\23_Abxoowbus_Trading_Post.cfg:1156
