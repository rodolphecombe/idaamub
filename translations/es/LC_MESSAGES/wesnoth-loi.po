#. [object]
#: .\utils\item_list.cfg:2914
msgid "Short farmer's bow"
msgstr "Arco corto de granjero"

#. [object]
#: .\utils\item_list.cfg:2923
msgid "What are you shooting arrows at? Chickens?"
msgstr "¿A qué disparas flechas? ¿A pollos?"

#. [object]
#: .\utils\item_list.cfg:2926 .\utils\item_list.cfg:2928
msgid "5 gold"
msgstr "5 de oro"

#. [object]
#: .\utils\item_list.cfg:2934
msgid ""
"Pure gold has a bright yellow color and luster traditionally considered "
"attractive, which it maintains without oxidizing in air or water. "
msgstr ""
"El oro puro tiene un color amarillo brillante y un lustre tradicionalmente "
"considerado atractivo, que mantiene sin oxidarse en el aire o el agua."

#. [object]
#: .\utils\item_list.cfg:2937 .\utils\item_list.cfg:2939
msgid "15 gold"
msgstr "15 de oro"

#. [object]
