msgid "No, not now."
msgstr "No, no ahora."

#. [option]
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:656
#: .\scenarios\chapter2\09_Spider_Maze.cfg:808
msgid "No, I don't want to know what's behind."
msgstr "No, no quiero saber qué hay detrás."

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:687
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:949
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:993
msgid "Argh! I'm burning! There was a trap."
msgstr "¡Argh! ¡Me quemo! Había una trampa."

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:731
msgid "Argh! I'm burning! The floor is trapped."
msgstr "¡Argh! ¡Me quemo! El piso está atrapado."

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:767
#: .\scenarios\chapter2\08_Inside_Uvju_s_cross.cfg:777
msgid "There are two large wooden doors. Should I try to open them?"
msgstr "Hay dos grandes puertas de madera. ¿Debo intentar abrirlas?"

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:783
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:827
