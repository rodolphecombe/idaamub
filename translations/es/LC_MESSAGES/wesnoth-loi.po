#. [scenario], id=12_Mine_Rats
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:4
msgid "Mine Rats"
msgstr "Ratas de Mina"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:35
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:41
msgid "Find a way to go to the lower level of the mine."
msgstr "Encuentra una forma de ir al nivel inferior de la mina."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:46
msgid "Find and destroy the rat nest before going down."
msgstr "Encuentra y destruye el nido de ratas antes de bajar."

#. [side], type=Direrat LoI
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:481
msgid "Rats"
msgstr "Ratas"

#. [side], type=Stone Golem
#. [side], type=Giant Scorpion
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:501
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:236
msgid "Scorpions"
msgstr "Escorpiones"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:564
msgid ""
"Let's recap. Our main mission is still to carry the message to Udxatfe. "
msgstr ""
"Recapitulemos. Nuestra misión principal sigue siendo llevar el mensaje a "
"Udxatfe. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:574
msgid ""
"If we can find him, it would be useful to also save Amin's brother, Hufifa, "
"as he probably has information about what is happening."
msgstr ""
"Si podemos encontrarlo, sería útil también salvar al hermano de Amin, "
"Hufifa, ya que probablemente tiene información sobre lo que está pasando."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:578
msgid "This should be our main mission."
msgstr "Esta debería ser nuestra misión principal."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:582
msgid ""
"We will do what we can to save your brother, but the fate of the world might "
"be at play here."
msgstr ""
"Haremos lo que podamos para salvar a tu hermano, pero el destino del mundo "
"podría estar en juego aquí."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:586
msgid "Which way is the elevator to the lower level?"
msgstr "¿Por cuál camino está el elevador al nivel inferior?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:590
msgid "*grumpy* It's north then west."
msgstr "*gruñón* Está al norte y luego al oeste."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:596
msgid ""
"If we can find him, it would be useful to also save Hufifa, as he probably "
"has information about what is happening."
msgstr ""
"Si podemos encontrarlo, sería útil también salvar a Hufifa, ya que "
"probablemente tiene información sobre lo que está pasando."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:629
msgid "Giant rats. The mine is swarming with them."
msgstr "Ratas gigantes. La mina está infestada de ellas."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:633
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:651
msgid "We tried to get rid of them, but we couldn't find the nest."
msgstr "Intentamos deshacernos de ellas, pero no pudimos encontrar el nido."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:637
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:655
msgid ""
"If we can find and destroy it, it would prevent them from attacking us from "
"behind."
msgstr ""
"Si podemos encontrarlo y destruirlo, evitaría que nos ataquen por la espalda."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:643
msgid "What's this? It looks like a rat, but far bigger."
msgstr "¿Qué es esto? Parece una rata, pero mucho más grande."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:647
msgid "Those are giant rats. The mine is swarming with them."
msgstr "Esas son ratas gigantes. La mina está infestada de ellas."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:683
msgid ""
"This is the ugliest rat I have ever seen. It must be their king or something "
"like that."
msgstr "Esta es la rata más fea que he visto. Debe ser su rey o algo así."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:716
msgid "Here are the scorpions I was talking about."
msgstr "Aquí están los escorpiones de los que hablaba."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:722
msgid "So those are the famous scorpions Amin told us about."
msgstr "Así que esos son los famosos escorpiones de los que nos habló Amin."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:730
msgid "Come on! Scorpions?! What else?! Flying tigers?!"
msgstr "¡Vamos! ¡¿Escorpiones?! ¡¿Qué más?! ¡¿Tigres voladores?!"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:838
msgid "What's this? It looks like a moving pile of rocks."
msgstr "¿Qué es esto? Parece un montón de rocas en movimiento."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:944
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1004
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1064
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1124
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1184
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1244
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:759
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1101
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1160
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1219
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1277
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1324
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1452
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:146
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:551
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:610
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:669
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:736
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:813
msgid "There's a barrel full of powder. Should I light it up?"
msgstr "Hay un barril lleno de polvo. ¿Debo encenderlo?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1354
msgid "I think I found the elevator."
msgstr "Creo que encontré el elevador."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1383
msgid "We don't have the time to fight rats. Let's go down."
msgstr "No tenemos tiempo para luchar contra ratas. Bajemos."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1395
msgid "The rats are dead. Let's go down."
msgstr "Las ratas están muertas. Bajemos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1416
msgid "Wait for us! We are still fighting the rats here!"
msgstr "¡Espérennos! ¡Aún estamos luchando contra las ratas aquí!"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1442
msgid ""
"Too many rats. We can't fight them and the orcs. We will have to find "
"another way."
msgstr ""
"Demasiadas ratas. No podemos luchar contra ellas y los orcos. Tendremos que "
"encontrar otra forma."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1448
msgid ""
"Too many orcs. We will never be able to reach Hufifa nor the exit of the "
"mine."
msgstr ""
"Demasiados orcos. Nunca podremos llegar a Hufifa ni a la salida de la mina."

#. [scenario], id=13_Miners_Life
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:6
msgid "Miners Life"
msgstr "Vida de Mineros"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:52
msgid "Clean the dwarvish living quarters."
msgstr "Limpia los cuartos de vivienda enanos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:708
msgid "Wow! It looks like there's a little welcoming commitee waiting for us. "
msgstr "¡Wow! Parece que hay un pequeño comité de bienvenida esperándonos. "

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1160
#: Legends_of_Idaamub/scenarios/chapter5/37_Old_Temple.cfg:514
msgid "Oh oh."
msgstr "Oh oh."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1409
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1502
msgid "I think I found an elevator."
msgstr "Creo que encontré un elevador."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1474
msgid ""
"Too many orcs and no way to go down. We will never be able to reach Hufifa "
"nor the exit of the mine."
msgstr ""
"Demasiados orcos y no hay forma de bajar. Nunca podremos llegar a Hufifa ni "
"a la salida de la mina."

#. [scenario], id=14_Mine_Maze
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:4
msgid "Mine Maze"
msgstr "Laberinto de Mina"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:40
msgid "Find your way through the mine."
msgstr "Encuentra tu camino a través de la mina."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:45
msgid "Defeat both orcish leaders."
msgstr "Derrota a ambos líderes orcos."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1371
msgid "There's three barrels full of powder. Should I light them up?"
msgstr "Hay tres barriles llenos de polvo. ¿Debo encenderlos?"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1568
msgid ""
"Scorpions, ghosts, mine worms, all that on top of the orcs. We won't go "
"further with that much enemies."
msgstr ""
"Escorpiones, fantasmas, gusanos de mina, todo eso además de los orcos. No "
"iremos más lejos con tantos enemigos."

#. [scenario], id=14b_Down_the_Elevator
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:4
msgid "Down the Elevator"
msgstr "Bajando el Elevador"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:27
msgid "Search the level."
msgstr "Busca el nivel."

#. [side], type=Stone Golem
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:68
msgid "monsters"
msgstr "monstruos"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:207
msgid ""
"I think I found the other elevator. It doesn't look like this tunnel goes "
"further."
msgstr ""
"Creo que encontré el otro elevador. No parece que este túnel vaya más lejos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:241
msgid "Wait for us. We're almost done."
msgstr "Espérennos. Casi terminamos."

#. [scenario], id=15_Ups_and_Downs
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:4
msgid "Ups and Downs"
msgstr "Subidas y Bajadas"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:40
msgid "Exit the mine."
msgstr "Sal de la mina."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:51
msgid "Find Hufifa before leaving."
msgstr "Encuentra a Hufifa antes de salir."

#. [side], type=Orcish Ruler
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:94
msgid "Orcs 1"
msgstr "Orcos 1"

#. [side], type=Orcish Ruler
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:129
msgid "Orcs 2"
msgstr "Orcos 2"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:430
msgid "Hufifa! My Brother! We found you!"
msgstr "¡Hufifa! ¡Hermano mío! ¡Te encontramos!"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:434
msgid "Aye! Well done, brother!"
msgstr "¡Sí! ¡Bien hecho, hermano!"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:440
msgid "Are you Hufifa?"
msgstr "¿Eres Hufifa?"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:444
msgid ""
"Of course I am! Have you heard of another dwarf kidnapped by those damn orcs?"
msgstr ""
"¡Por supuesto que soy! ¿Has oído de otro enano secuestrado por esos malditos "
"orcos?"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:448
msgid "Anyway, well done!"
msgstr "¡De todos modos, bien hecho!"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:454
msgid ""
"Those losers weren’t really any threat, but I would bet my mine that someone "
"is pulling the strings behind them!"
msgstr ""
"¡Esos perdedores no eran realmente una amenaza, pero apostaría mi mina a que "
"alguien está tirando de los hilos detrás de ellos!"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:458
msgid ""
"The guardian of Udxatfe must be warned, and quickly! If you go that way, I "
"would be grateful if you could warn everyone."
msgstr ""
"¡El guardián de Udxatfe debe ser advertido, y rápido! Si van por ese camino, "
"estaría agradecido si pudieran advertir a todos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:462
msgid "What if he doesn't believe us?"
msgstr "¿Y si no nos cree?"

#. [message], speaker=Csia
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:472
msgid "He knows me. I should be enough of a proof that our story is true."
msgstr ""
"Me conoce. Debería ser suficiente prueba de que nuestra historia es "
"verdadera."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:476
msgid "Anyway, take that."
msgstr "De todos modos, toma eso."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:481
msgid ""
"It's my lucky-charm. That’s the least I can do, after all you’ve done for "
"me. "
msgstr ""
"Es mi amuleto de la suerte. Es lo mínimo que puedo hacer, después de todo lo "
"que han hecho por mí. "

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:487
msgid ""
"If the guardian gives you troubles, show him my lucky-charm and he will know "
"that I’m sending you."
msgstr ""
"Si el guardián les da problemas, muéstrenle mi amuleto de la suerte y sabrá "
"que yo los envío."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:491
msgid "You can even keep it. Take."
msgstr "Incluso pueden quedárselo. Tomen."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:496
msgid "That’s the least I can do, after all you’ve done for me."
msgstr "Es lo mínimo que puedo hacer, después de todo lo que han hecho por mí."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:520
msgid "Brother, go with them. They will need your help."
msgstr "Hermano, ve con ellos. Necesitarán tu ayuda."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:524
msgid "Aye, brother. Take care of the mine while I'm away."
msgstr "Sí, hermano. Cuida la mina mientras estoy ausente."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:528
msgid ""
"As if I ever needed you to take care of the mine. Try not to get killed."
msgstr ""
"Como si alguna vez te necesitara para cuidar la mina. Intenta no morir."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:865
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1032
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1244
msgid "There's a lever to make the elevator go down. Do you want to pull it?"
msgstr "Hay una palanca para hacer bajar el elevador. ¿Quieres jalarla?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:958
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1101
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1170
msgid "There's a lever to make the elevator go up. Do you want to pull it?"
msgstr "Hay una palanca para hacer subir el elevador. ¿Quieres jalarla?"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1427
msgid "I'm sorry Amin, but we don't have the time to find your brother."
msgstr "Lo siento Amin, pero no tenemos tiempo para encontrar a tu hermano."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1431
msgid ""
"Well, I don't have the time to help you either! I will stay here and find my "
"brother."
msgstr ""
"¡Bueno, yo tampoco tengo tiempo para ayudarte! Me quedaré aquí y encontraré "
"a mi hermano."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1455
msgid "You can now longer recruit nor recall Dwarvish Fighters."
msgstr "Ya no puedes reclutar ni reincorporar Luchadores Enanos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1461
msgid ""
"It is a bit sad that we did not find the dwarf, but we don't have the time "
"to search for him."
msgstr ""
"Es un poco triste que no encontramos al enano, pero no tenemos tiempo para "
"buscarlo."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1475
msgid "Hufifa is safe. We can now leave the mine without any regret."
msgstr ""
"Hufifa está a salvo. Ahora podemos dejar la mina sin ningún remordimiento."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1511
msgid "Wait for us! We will try to find Hufifa before leaving."
msgstr "¡Espérennos! Intentaremos encontrar a Hufifa antes de salir."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1532
msgid "We can't find Hufifa, nor the exit. We will probably die in this mine."
msgstr ""
"No podemos encontrar a Hufifa, ni la salida. Probablemente moriremos en esta "
"mina."

#. [scenario], id=16_Snow_Wizards
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:4
msgid "Snow Wizards"
msgstr "Magos de Nieve"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:40
msgid "Reach Udxatfe."
msgstr "Llega a Udxatfe."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:51
msgid "Defeat all enemy leaders before reaching Udxatfe"
msgstr "Derrota a todos los líderes enemigos antes de llegar a Udxatfe"

#. [side], type=Ice Troll LoI
#. [side], type=Ice Troll Warrior LoI
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:94
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:82
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:95
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:107
msgid "Ice Trolls"
msgstr "Trolls de Hielo"

#. [side], type=Great Wolf
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:135
msgid "Wolves"
msgstr "Lobos"

#. [side], type=Ogre
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:242
msgid "Ogres"
msgstr "Ogros"

#. [side], type=Swordsman
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:268
msgid "Guards"
msgstr "Guardias"

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:381
msgid ""
"West: Qyizu’s Mine. \n"
"South: Udxatfe"
msgstr ""
"Oeste: Mina de Qyizu. \n"
"Sur: Udxatfe"

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:400
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:436
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:454
msgid "East: Udxatfe"
msgstr "Este: Udxatfe"

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:418
msgid "North: Udxatfe"
msgstr "Norte: Udxatfe"

#. [message], speaker=Innec
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:471
msgid ""
"Never had I seen wolves attacking an armed group. Something has probably "
"made them nervous."
msgstr ""
"Nunca había visto lobos atacando a un grupo armado. Algo probablemente los "
"ha hecho nerviosos."

#. [message], speaker=Addthynaent
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:491
msgid "Welcome stranger."
msgstr "Bienvenido extraño."

#. [message], speaker=Addthynaent
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:495
msgid ""
"The Guardian wishes to see all those coming from the south. Sorry, Legion’s "
"order."
msgstr ""
"El Guardián desea ver a todos los que vienen del sur. Lo siento, orden de la "
"Legión."

#. [message], speaker=Addthynaent
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:499
msgid "You will certainly find him at the Blessed Uaja’s Inn."
msgstr "Seguramente lo encontrarás en la Posada del Bendito Uaja."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:529
#: Legends_of_Idaamub/scenarios/chapter4/25_Troll_Cave.cfg:578
msgid "Wait for us! We are still fighting the trolls here!"
msgstr "¡Espérennos! ¡Aún estamos luchando contra los trolls aquí!"

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:552
msgid "What's this? It looks like some kind of troll. "
msgstr "¿Qué es esto? Parece algún tipo de troll. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:564
msgid "It doesn't look very happy finding us on its territory."
msgstr "No parece muy feliz de encontrarnos en su territorio."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:574
msgid "I'm afraid we will have to fight to reach Udxatfe."
msgstr "Temo que tendremos que luchar para llegar a Udxatfe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:633
msgid "So cold..."
msgstr "Tan frío..."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:637
msgid "Feeling numb..."
msgstr "Sintiéndome entumecido..."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:641
msgid "Must not..."
msgstr "No debo..."

#. [scenario], id=17_Udxatfe
#. [side], type=Lieutenant
#. [side], type=Swordsman
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:4
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:139
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:202
msgid "Udxatfe"
msgstr "Udxatfe"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:72
msgid "Talk to the Guardian."
msgstr "Habla con el Guardián."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:82
msgid "Leave Udxatfe."
msgstr "Sal de Udxatfe."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:93
msgid "Find the two remaining books."
msgstr "Encuentra los dos libros restantes."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:104
msgid "Find Roiwv, Owreddoc's sister."
msgstr "Encuentra a Roiwv, la hermana de Owreddoc."

#. [side], type=Ice Troll Hero LoI
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:379
msgid "Ice trolls"
msgstr "Trolls de hielo"

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:459
msgid "Bye then."
msgstr "Adiós entonces."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:478
msgid "Oh! I see, you’re reading one of those Oa’s books."
msgstr "¡Oh! Veo que estás leyendo uno de esos libros de Oa."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:482
msgid "Those are fine reading! I finished this one."
msgstr "¡Que buena lectura! Terminé este."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:486
msgid ""
"I can lend it to you but don’t forget to bring it back to that mage child "
"once you’re done."
msgstr ""
"Puedo prestártelo pero no olvides devolvérselo a ese niño mago una vez que "
"termines."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:490
msgid "Sure. We'll bring it back."
msgstr "Claro. Lo devolveremos."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:648
msgid "She says Teumiuxe the mage is prisoner in the ice caves."
msgstr "Dice que Teumiuxe el mago es prisionero en las cuevas de hielo."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:693
msgid "Sure, how much do you need?"
msgstr "Claro, ¿cuánto necesitas?"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:853
msgid "Greetings. You are a long way from home."
msgstr "Saludos. Estás lejos de casa."

#. [message], speaker=Csia
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:857
msgid ""
"Indeed. I am here to warn you that orcs attacked Zei and are roaming the "
"land around."
msgstr ""
"En efecto. Estoy aquí para advertirte que orcos atacaron Zei y están vagando "
"por la tierra alrededor."

#. [message], speaker=Csia
#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:861
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:879
msgid "We had to fight our way to here."
msgstr "Tuvimos que luchar para llegar aquí."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:865
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:883
msgid "By the dragon, it looks like I missed a nice fight."
msgstr "Por el dragón, parece que me perdí una buena pelea."

#. [message], speaker=Csia
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:869
msgid "Men have died!"
msgstr "¡Hombres han muerto!"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:875
msgid ""
"We come in behalf of Csia of Zei to warn you that orcs attacked the city and "
"are roaming the land around."
msgstr ""
"Venimos en nombre de Csia de Zei para advertirte que orcos atacaron la "
"ciudad y están vagando por la tierra alrededor."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:887
msgid "Well... that's one way to see it..."
msgstr "Bueno... esa es una forma de verlo..."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:893
msgid ""
"Ha! The legionaries are saying it is even worse on the other side of the "
"mountain."
msgstr "¡Ja! Los legionarios dicen que es aún peor al otro lado de la montaña."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:897
msgid ""
"Dunefolk mounted archers are pillaging villages east and I heard orcish "
"marauders are looking for some kind of magic artifact…"
msgstr ""
"Arqueros montados barjanes están saqueando aldeas al este y escuché que "
"merodeadores orcos buscan algún tipo de artefacto mágico…"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:912
msgid "Excuse me, what is happening here?"
msgstr "Disculpe, ¿qué está pasando aquí?"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:916
msgid ""
"Everything began the day our great mage Teumiuxe disappeared and if you want "
"my opinion, it’s not a coincidence!"
msgstr ""
"Todo comenzó el día que nuestro gran mago Teumiuxe desapareció y si quieres "
"mi opinión, ¡no es una coincidencia!"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:920
msgid ""
"That mad innkeeper says she knows where he is, but I tell you he is dead or "
"kept as a hostage at our little friend's from East."
msgstr ""
"Esa posadera loca dice que sabe dónde está, pero te digo que está muerto o "
"mantenido como rehén por nuestros amiguitos del Este."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:941
msgid "Can we do something to help?"
msgstr "¿Podemos hacer algo para ayudar?"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:945
msgid "You seems like capable people."
msgstr "Parecen personas capaces."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:949
msgid "I need someone to go east and find Teumiuxe, dead or alive."
msgstr ""
"Necesito a alguien que vaya al este y encuentre a Teumiuxe, muerto o vivo."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:953
msgid "Find him and you’ll find at the same time the reason for this mess!"
msgstr "¡Encuéntrenlo y encontrarán al mismo tiempo la razón de este desastre!"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1004
msgid "Me Uwiu. Strong warrior."
msgstr "Yo Uwiu. Guerrero fuerte."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1019
msgid "Chief tell Uwiu bring caravan Idaamub’s kingdom."
msgstr "Jefe decir Uwiu llevar caravana reino de Idaamub."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1023
msgid "Uwiu bring Zei and stupid orcs burn city!"
msgstr "¡Uwiu llevar Zei y orcos estúpidos quemar ciudad!"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1027
msgid "Driver steal wagon, steal gold Uwiu and flee."
msgstr "Conductor robar carro, robar oro Uwiu y huir."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1031
msgid "Uwiu follow to Udxatfe but can’t go further."
msgstr "Uwiu seguir a Udxatfe pero no poder ir más lejos."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1050
msgid "Uwiu help you if you help him. Uwiu need 1700 gold."
msgstr "Uwiu ayudar si ayudar a él. Uwiu necesitar 1700 oro."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1054
msgid "Uwiu good to strike, hit, break…"
msgstr "Uwiu bueno para golpear, pegar, romper…"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1058
msgid "Everything and everyone!"
msgstr "¡Todo y todos!"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1062
msgid "You OK?"
msgstr "¿Tú bien?"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1074
msgid "Not enough gold."
msgstr "No suficiente oro."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1078
msgid "Uwiu need gold or no go back home."
msgstr "Uwiu necesitar oro o no volver casa."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1099
msgid "Ah-ah! You make perfect choice! Excellent!"
msgstr "¡Ah-ah! ¡Tú hacer elección perfecta! ¡Excelente!"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1103
msgid "We have fun a lot hit orcs, save kingdom!"
msgstr "¡Nosotros divertir mucho golpear orcos, salvar reino!"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1118
msgid "You think about that."
msgstr "Tú pensar en eso."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1122
msgid "Uwiu wait, stay here for when you want strong warrior, OK?"
msgstr "¿Uwiu esperar, quedarse aquí para cuando querer guerrero fuerte, bien?"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1126
msgid "Well. well. See you later."
msgstr "Bueno. Bueno. Nos vemos después."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1178
msgid "I'm Asaem, a mage."
msgstr "Soy Asaem, un mago."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1182
msgid ""
"I’m the best mage around. I might be a bit decrepit, but my fireballs were "
"already grilling goblins when your grandfather was still wearing diapers."
msgstr ""
"Soy el mejor mago por aquí. Podría estar un poco decrépito, pero mis bolas "
"de fuego ya asaban goblins cuando tu abuelo aún usaba pañales."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1197
msgid "I was in a quest with other adventurers, but it went poorly."
msgstr "Estaba en una búsqueda con otros aventureros, pero salió mal."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1205
msgid ""
"In this inn where we met, I bumped into 5 to 6 soldiers. At least 4 wanted "
"to hit me. Instead they trampled my black cat."
msgstr ""
"En esta posada donde nos encontramos, choqué con 5 o 6 soldados. Al menos 4 "
"querían golpearme. En cambio pisotearon mi gato negro."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1209
msgid ""
"If I had known this spell, it never would have happened. If I had known this "
"spell, unfortunately I had forgotten it."
msgstr ""
"Si hubiera conocido este hechizo, nunca habría pasado. Si hubiera conocido "
"este hechizo, desafortunadamente lo había olvidado."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1213
msgid ""
"We arrived at the dungeon door, I wanted to try to lockpick it. Then a trap "
"triggered, and the rogue got killed."
msgstr ""
"Llegamos a la puerta del calabozo, quería intentar forzar la cerradura. "
"Luego una trampa se activó, y el pícaro murió."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1217
msgid ""
"If I had had my scroll, I could have detected it. If I had had my scroll, "
"but it was covered all over with wine stains."
msgstr ""
"Si hubiera tenido mi pergamino, podría haberlo detectado. Si hubiera tenido "
"mi pergamino, pero estaba cubierto por completo con manchas de vino."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1221
msgid ""
"In the first corridor we were exploring, a herd of orcs arrived. I cast a "
"fireball at them. But the dwarf received it."
msgstr ""
"En el primer pasillo que explorábamos, llegó una manada de orcos. Lancé una "
"bola de fuego a ellos. Pero el enano la recibió."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1225
msgid ""
"If I had had this old book, I would probably have aimed better. If I had had "
"this old book, the one I lost the evening before."
msgstr ""
"Si hubiera tenido este viejo libro, probablemente habría apuntado mejor. Si "
"hubiera tenido este viejo libro, el que perdí la noche anterior."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1229
msgid ""
"In the cellar that we escaped, we thought we were safe. Then we ran into a "
"troll, of course the elf got eaten."
msgstr ""
"En el sótano al que escapamos, pensábamos que estábamos a salvo. Luego nos "
"topamos con un troll, por supuesto el elfo fue comido."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1233
msgid ""
"If I had grabbed my wand, I could have petrified it. If I had grabbed my "
"wand. I did not because it was in pieces."
msgstr ""
"Si hubiera agarrado mi varita, podría haberlo petrificado. Si hubiera "
"agarrado mi varita. No lo hice porque estaba en pedazos."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1237
msgid ""
"In the catacombs we were hiding in, I brushed against a huge bell. The "
"dragon I awoke used the warrior as his breakfast."
msgstr ""
"En las catacumbas donde nos escondíamos, rozé una enorme campana. El dragón "
"que desperté usó al guerrero como desayuno."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1241
msgid ""
"If I had had the One Ring, I would have crushed this dragon. If I had had "
"the One Ring that was stolen one day from me by a hobbit."
msgstr ""
"Si hubiera tenido el Anillo Único, habría aplastado a este dragón. Si "
"hubiera tenido el Anillo Único que me robaron un día un hobbit."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1245
msgid "I am not sure if he is unsafe or just mad as a hatter."
msgstr "No estoy seguro si es inseguro o solo loco como una cabra."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1264
msgid ""
"If the Guardian decided to give you an impossible quest, I need to give you "
"at least a chance to stay alive."
msgstr ""
"Si el Guardián decidió darte una búsqueda imposible, necesito darte al menos "
"una oportunidad de quedarte vivo."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1270
msgid "I just need 1950 gold to pay my bill at the inn."
msgstr "Solo necesito 1950 oro para pagar mi cuenta en la posada."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1274
msgid ""
"If you have enough to pay my bill, we can go before you can say Jack "
"Robinson."
msgstr ""
"Si tienes suficiente para pagar mi cuenta, podemos ir antes de que digas "
"Jack Robinson."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1278
msgid "It's up to you."
msgstr "Depende de ti."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1290
msgid "I'm sorry, but there is not enough to pay my bill"
msgstr "Lo siento, pero no hay suficiente para pagar mi cuenta"

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1311
msgid "Well. Then, let’s go."
msgstr "Bueno. Entonces, vamos."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1326
msgid "You’re quite reckless but do as you feel."
msgstr "Eres bastante imprudente pero haz lo que sientas."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1330
msgid "I’ll be there when you’ll be back to your mind."
msgstr "Estaré allí cuando regreses a tu mente."

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1427
msgid "It’s quite cold, isn’t it?"
msgstr "¿Hace bastante frío, no?"

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1431
msgid ""
"Gods be blessed, I don’t have to live here year long. I only come to do some "
"experiments."
msgstr ""
"Dioses benditos, no tengo que vivir aquí todo el año. Solo vengo a hacer "
"algunos experimentos."

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1435
msgid "Fire and ice spells, that kind of things."
msgstr "Hechizos de fuego y hielo, ese tipo de cosas."

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1439
msgid ""
"You see, I’ve a theory about that: if the spells work fine here, it should "
"be the same anywhere else. Udxatfe has always been a special place where "
"magic holds an important place! "
msgstr ""
"Verás, tengo una teoría sobre eso: si los hechizos funcionan bien aquí, "
"debería ser lo mismo en cualquier otro lugar. ¡Udxatfe siempre ha sido un "
"lugar especial donde la magia ocupa un lugar importante! "

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1443
msgid "Probably because of the magic ice cave in the North."
msgstr "Probablemente por la cueva de hielo mágica en el Norte."

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1493
msgid "You can look at my potions and spells if you’re interested."
msgstr "Puedes mirar mis pociones y hechizos si estás interesado."

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1545
#: Legends_of_Idaamub/utils/item_list.cfg:5421
msgid "A Dynamical Theory of the Electromagnetic Field"
msgstr "Una Teoría Dinámica del Campo Electromagnético"

