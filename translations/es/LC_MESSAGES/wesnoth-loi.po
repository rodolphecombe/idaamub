"<span color='blue'>Max experience decreased by 4 XP.</span>"
msgstr ""
"<span color='green'>Daño aumentado en 23%</span>\n"
"<span color='green'>25% menos ataques</span>\n"
"<span color='blue'>Experiencia máxima reducida en 4 XP.</span>"

