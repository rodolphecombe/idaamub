#: Legends_of_Idaamub/utils/item_list.cfg:6951
msgid "Still hot."
msgstr "Aún caliente."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:6954
msgid "Ripper staff of the fox"
msgstr "Bastón rasgador del zorro"

