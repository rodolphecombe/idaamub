#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:2005
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:2041
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1903
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1939
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1975
msgid "You don't have enough money."
msgstr "No tienes suficiente dinero."

#. [message], speaker=Io
#: .\scenarios\chapter2\06_Zei.cfg:1904 .\scenarios\chapter2\06_Zei.cfg:1932
#: .\scenarios\chapter2\06_Zei.cfg:1960 .\scenarios\chapter2\11_Qyizu.cfg:1963
#: .\scenarios\chapter2\11_Qyizu.cfg:1999
#: .\scenarios\chapter2\11_Qyizu.cfg:2035
#: .\scenarios\chapter3\17_Udxatfe.cfg:720
#: .\scenarios\chapter3\17_Udxatfe.cfg:748
#: .\scenarios\chapter3\17_Udxatfe.cfg:776
