msgstr "Bastón de Teumiuxe"

#. [object]
#: .\utils\item_list.cfg:13493
msgid ""
"<span color='green'>Damage increased by 108 %.</span>\n"
"<span color='#60A0FF'>Resistance to arcane increased by 6%.</span>\n"
"<span color='#60A0FF'>Resistance to fire increased by 6%.</span>\n"
"<span color='#60A0FF'>Resistance to cold increased by 6%.</span>\n"
