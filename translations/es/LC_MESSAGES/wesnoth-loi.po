#. [message], speaker=Gwatharvan
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2630
msgid "Then leave! And shut the door tightly!"
msgstr "¡Entonces vete! ¡Y cierra la puerta con fuerza!"

#. [message], speaker=Gwatharvan
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2649
msgid ""
"Oh, you’re looking for books? To tell the truth, Teoran just lent me one."
msgstr "Oh, ¿buscas libros? Para decir la verdad, Teoran me prestó uno."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2653
msgid "He needs it back."
msgstr "Lo necesita de vuelta."

#. [message], speaker=Gwatharvan
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2657
msgid "No problem. Here it is. You can thank him for me."
msgstr "No hay problema. Aquí está. Puedes agradecerle de mi parte."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2661
msgid "Sure. We'll bring him back."
msgstr "Claro. Lo devolveremos."

#. [message], speaker=Derrreddoc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2738
msgid "Of course they are. But I won't give it to you for free."
msgstr "Por supuesto que lo son. Pero no te lo daré gratis."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2804
msgid ""
"My friends, our new mission is to find Teumiuxe the mage. We were told he is "
"a prisoner in the ice caves in the North."
msgstr ""
"Mis amigos, nuestra nueva misión es encontrar a Teumiuxe el mago. Nos "
"dijeron que está prisionero en las cuevas de hielo en el Norte."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2808
msgid ""
"*To himself* I hope he is alive. He might know what is happening, and we "
"will need him to save Idaamub. "
msgstr ""
"*Para sí mismo* Espero que esté vivo. Podría saber qué está pasando, y lo "
"necesitaremos para salvar Idaamub. "

#. [scenario], id=18_In_the_Snow
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:4
msgid "In the Snow"
msgstr "En la Nieve"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:26
msgid "Go north"
msgstr "Ve al norte"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:31
msgid "Find the path to Ery's house"
msgstr "Encuentra el camino a la casa de Ery"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:295
msgid "There is a path here. It seems to lead to a house."
msgstr "Hay un camino aquí. Parece llevar a una casa."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:311
msgid "Let's go."
msgstr "Vamos."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:324
msgid "Wait for us"
msgstr "Espérennos"

#. [message], speaker=unit
#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:348
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:968
msgid "Let's continue."
msgstr "Continuemos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:362
msgid "Wait for us."
msgstr "Espérennos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:418
msgid "It was the wrong week to go north."
msgstr "Fue la semana equivocada para ir al norte."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:422
msgid "We should have stayed in the inn with a good stew."
msgstr "Deberíamos habernos quedado en la posada con un buen estofado."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:426
msgid "Now they will only find our frozen corpses in several months."
msgstr "Ahora solo encontrarán nuestros cadáveres congelados en varios meses."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:42
msgid "Find the road to the ice caves"
msgstr "Encuentra el camino a las cuevas de hielo"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:53
msgid "Clean the cave"
msgstr "Limpia la cueva"

#. [side], type=Ice Crab
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:183
msgid "Frost Monsters"
msgstr "Monstruos de Escarcha"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:503
msgid ""
"The cave is clean. Now let's continue to the ice caves. The road should be "
"east from the house."
msgstr ""
"La cueva está limpia. Ahora continuemos a las cuevas de hielo. El camino "
"debería estar al este de la casa."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:513
msgid "Let's take a look at the chest before leaving."
msgstr "Echemos un vistazo al cofre antes de irnos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:523
msgid "Look what we have here."
msgstr "Mira lo que tenemos aquí."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:572
msgid "This is pointless! Let's go back to the road where we left it."
msgstr "¡Esto es inútil! Volvamos al camino donde lo dejamos."

#. [scenario], id=19_Frozen_Maze
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:4
msgid "Frozen Maze"
msgstr "Laberinto Congelado"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:45
#: Legends_of_Idaamub/scenarios/chapter4/25_Troll_Cave.cfg:32
msgid "Defeat the troll leader"
msgstr "Derrota al líder troll"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:55
msgid "Continue north"
msgstr "Continúa al norte"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:629
msgid "It's getting foggy out there."
msgstr "Se está poniendo brumoso allá afuera."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:633
msgid "I think I can see a path though."
msgstr "Creo que puedo ver un camino sin embargo."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:637
msgid "Wait! I see two!"
msgstr "¡Espera! ¡Veo dos!"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:641
#: Legends_of_Idaamub/scenarios/chapter4/26_Echo_Chamber.cfg:369
#: Legends_of_Idaamub/scenarios/chapter4/26_Echo_Chamber.cfg:465
msgid "Which way should we go?"
msgstr "¿Por cuál camino deberíamos ir?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:647
msgid "Let's go North. That should be the way to the ice caves."
msgstr "Vamos al Norte. Ese debería ser el camino a las cuevas de hielo."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:663
msgid "Let's go East. That should be the way to the ice caves."
msgstr "Vamos al Este. Ese debería ser el camino a las cuevas de hielo."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:679
#: Legends_of_Idaamub/scenarios/chapter4/26_Echo_Chamber.cfg:435
msgid "Let's decide later. We are not done here."
msgstr "Decidamos después. No hemos terminado aquí."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:708
msgid "So...cold..."
msgstr "Tan...frío..."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:712
msgid "Can't...think..."
msgstr "No...puedo...pensar..."

#. [scenario], id=19b_Northern_Lights
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:4
msgid "Northern Lights"
msgstr "Luces del Norte"

#. [time], id=bright_dawn
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:12
msgid "Bright Dawn"
msgstr "Amanecer Brillante"

#. [time], id=midday
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:22
msgid "Midday"
msgstr "Mediodía"

#. [time], id=bright_dusk
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:28
msgid "Bright Dusk"
msgstr "Atardecer Brillante"

#. [time], id=first_aurora
#. [time], id=midnight_aurora
#. [time], id=second_aurora
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:38
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:46
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:54
msgid "Aurora Borealis"
msgstr "Aurora Boreal"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:83
msgid "Explore"
msgstr "Explorar"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:94
msgid "Kill all scorpions"
msgstr "Mata a todos los escorpiones"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:410
msgid "The fog is clearing down here."
msgstr "La niebla se está disipando aquí abajo."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:456
msgid "Well, cleary, this path is not leading to the ice caves."
msgstr "Bueno, claramente, este camino no lleva a las cuevas de hielo."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:460
msgid "We don't have more time to spend here. Let's head back."
msgstr "No tenemos más tiempo para pasar aquí. Volvamos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:484
msgid "No more scorpions. We did it."
msgstr "No más escorpiones. Lo logramos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:488
msgid "Obviously, this path is not leading to the ice caves. Let's go back."
msgstr "Obviamente, este camino no lleva a las cuevas de hielo. Volvamos."

#. [scenario], id=20_Ice_Cave
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:4
msgid "Ice_Cave"
msgstr "Cueva_de_Hielo"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:51
#: Legends_of_Idaamub/scenarios/chapter3/22_Ice_Prison.cfg:30
msgid "Find Teumiuxe"
msgstr "Encuentra a Teumiuxe"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:62
msgid "Defeat the enemy leader before going east"
msgstr "Derrota al líder enemigo antes de ir al este"

#. [side], type=Ice Guard LoI
#. [side], type=Ice Swordsman LoI
#. [side], type=Frozen Lich LoI
#. [side], type=Ice Bat LoI
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:106
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:123
#: Legends_of_Idaamub/scenarios/chapter3/21_Frozen_Chasm.cfg:85
#: Legends_of_Idaamub/scenarios/chapter3/22_Ice_Prison.cfg:74
msgid "Ice Beings"
msgstr "Seres de Hielo"

#. [side], type=Ice Troll Shaman LoI
#. [side], type=Ice Bat LoI
#. [side], type=Troll Warrior
#. [side], type=Troll Hero
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:517
#: Legends_of_Idaamub/scenarios/chapter3/22_Ice_Prison.cfg:390
#: Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:190
#: Legends_of_Idaamub/scenarios/chapter4/25_Troll_Cave.cfg:76
#: Legends_of_Idaamub/scenarios/chapter4/26b_Troll_Fort.cfg:92
msgid "Trolls"
msgstr "Trolls"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:705
msgid "The door opened when I approched."
msgstr "La puerta se abrió cuando me acerqué."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:716
msgid "Let's see what's in there."
msgstr "Veamos qué hay ahí."

#. [message], speaker=$opener.id
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:765
msgid "I think I just saw this flying piece of ice come out a block of ice."
msgstr ""
"Creo que acabo de ver este pedazo de hielo volador salir de un bloque de "
"hielo."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:803
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:828
msgid "It looks like I stepped on some mechanism."
msgstr "Parece que pisé algún mecanismo."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:832
msgid "Look what I found."
msgstr "Mira lo que encontré."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:848
msgid ""
"South-west : Udxatfe\n"
"North-east : Abxoowbu’s trading post"
msgstr ""
"Suroeste : Udxatfe\n"
"Noreste : Puesto comercial de Abxoowbu"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:948
msgid "This cave is bigger than I thought. And still no sign of Teumiuxe."
msgstr ""
"Esta cueva es más grande de lo que pensaba. Y aún no hay señal de Teumiuxe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:952
msgid ""
"I did not expect him to be held prisoner right at the entrance, but still."
msgstr ""
"No esperaba que estuviera prisionero justo en la entrada, pero aun así."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:958
msgid ""
"This cave is bigger than I thought. But we now have an hint on where "
"Teumiuxe is."
msgstr ""
"Esta cueva es más grande de lo que pensaba. Pero ahora tenemos una pista "
"sobre dónde está Teumiuxe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:962
msgid ""
"It's not like we were expecting him to be held prisoner right at the "
"entrance anyway."
msgstr ""
"No es como si esperáramos que estuviera prisionero justo en la entrada de "
"todos modos."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:1006
msgid "This cave is bigger than I thought. And still now sign of Teumiuxe."
msgstr ""
"Esta cueva es más grande de lo que pensaba. Y aún no hay señal de Teumiuxe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:1010
msgid "It is getting too difficult with all those ice beings coming at us."
msgstr ""
"Se está poniendo demasiado difícil con todos esos seres de hielo viniendo "
"hacia nosotros."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/20_Ice_Cave.cfg:1014
msgid "Let's go back to Udxatfe to ask for help."
msgstr "Volvamos a Udxatfe a pedir ayuda."

#. [scenario], id=21_Frozen_Chasm
#: Legends_of_Idaamub/scenarios/chapter3/21_Frozen_Chasm.cfg:4
msgid "Frozen Chasm"
msgstr "Abismo Congelado"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/21_Frozen_Chasm.cfg:31
msgid "Defeat who is corrupting the magic"
msgstr "Derrota a quien está corrompiendo la magia"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/21_Frozen_Chasm.cfg:41
msgid "Defeat the transformed lich"
msgstr "Derrota al liche transformado"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/21_Frozen_Chasm.cfg:213
#: Legends_of_Idaamub/scenarios/chapter4/26_Echo_Chamber.cfg:518
