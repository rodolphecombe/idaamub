#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2166
#: Legends_of_Idaamub/utils/item_list.cfg:6629
#: Legends_of_Idaamub/utils/item_list.cfg:8380
msgid "Staff of outburst"
msgstr "Bastón de estallido"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2194
#: Legends_of_Idaamub/utils/item_list.cfg:6576
msgid "High-calibre bow"
msgstr "Arco de alto calibre"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2195
#: Legends_of_Idaamub/utils/item_list.cfg:6498
msgid "Midnight slippery bow"
msgstr "Arco resbaladizo de medianoche"

#. [message], speaker=trader
