msgstr ""

#. [message], speaker=trader
#. [object]
#: .\scenarios\chapter5\35_Scavengers_Trading_Post.cfg:1580
#: .\utils\item_list.cfg:14046
msgid "Avenging burning winged mace"
msgstr ""

