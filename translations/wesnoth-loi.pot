#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1530
msgid "There is a huge metal door. Should I open it?"
msgstr ""

#. [option]
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1068
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1111
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1154
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1197
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1269
