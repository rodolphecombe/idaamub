#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:769
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:812
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:856
msgid ""
"The orcs couldn't have made it. The creation of a golem requires far more "
"magic than animating skeletons."
msgstr ""

#. [message], speaker=Amin
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:779
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:816
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:866
msgid "You're only half right."
msgstr ""

#. [message], speaker=Amin
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:783
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:820
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:870
msgid ""
"The orcs haven't made them, but it is not natural either. They were brought "
"here by the demons and as they can't die, they are still roaming the place."
msgstr ""

#. [message], speaker=Amin
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:787
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:824
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:874
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:900
msgid ""
"We discover one of them from time to time while mining. They are strong "
"against axes, less against hammers."
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:791
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:828
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:878
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:904
msgid "Are there other creatures we should worry about?"
msgstr ""

#. [message], speaker=Amin
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:795
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:832
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:882
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:908
msgid "There are some more, like scorpions or shadows, so we must be careful."
msgstr ""

#. [message], speaker=Lujeje
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:808
msgid "Interesting. It is probably natural."
msgstr ""

#. [message], speaker=unit
#: ./Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:838
