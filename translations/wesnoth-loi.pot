msgid "Argh! I'm burning! The floor is trapped."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter1\04_Crypt_of_the_Sacred_Blood.cfg:770
#: .\scenarios\chapter2\08_Inside_Uvju_s_cross.cfg:779
msgid "There are two large wooden doors. Should I try to open them?"
msgstr ""

