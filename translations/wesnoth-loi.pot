#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1660
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1678
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1729
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1747
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1899
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1935
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1971
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:2007
msgid "No, not right now."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1226
msgid "There are two huge metal doors. Should I open them?"
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1264
msgid "There're opened."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1440
msgid "There're corpses in there."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1450
msgid ""
"I'm afraid they are those of the treasure hunter we were supposed to look "
"for. They were probably killed by the saurians."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1454
msgid ""
"Let's go back to the surface and warn Oboavlidlu so that he can give them a "
"decent burial."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1461
msgid "Poor fellows. It looks like they were killed by the saurians."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1467
msgid ""
"It looks like one of their horses survived though. Maybe we could take him "
"with us?"
msgstr ""

#. [option]
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1506
msgid "No, leave it be. It might be someone's horse."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:1573
msgid "It looks like this wall is made of earth. Should I try to dig through?"
