#. [message], speaker=Vygwynyc
#. [message], speaker=trader
#. [message], speaker=Aenyc
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:1937
#: ./Legends_of_Idaamub/scenarios/chapter2/11_Qyizu.cfg:2034
#: ./Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:787
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:1349
#: ./Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1738
#: ./Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2049
#: ./Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1985
msgid "Do you have something to transport it?"
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:1941
#: ./Legends_of_Idaamub/scenarios/chapter2/11_Qyizu.cfg:2038
#: ./Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:791
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:1353
#: ./Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1742
#: ./Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2053
#: ./Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1989
msgid "Unfortunately not."
msgstr ""

#. [message], speaker=Vygwynyc
#. [message], speaker=trader
#. [message], speaker=Aenyc
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:1945
#: ./Legends_of_Idaamub/scenarios/chapter2/11_Qyizu.cfg:2042
#: ./Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:795
#: ./Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1746
#: ./Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2057
#: ./Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1993
msgid "Come back when you do then."
msgstr ""

#. [option]
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:1982
msgid "You look injured. What happened to you?"
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:1986
msgid ""
"Sorry for not being very presentable. I got hit by an arrow last night but "
"it's only a scratch."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:1990
msgid "But I'm ready to go back to the fight, if someone finally believes in me."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2005
msgid "I'm Is, the bowwoman. If your need a good bowman, don't look further."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2020
msgid "Gaelyn fixed me after I was injured defending the village."
msgstr ""

#. [option]
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2031
msgid "Can we help you with something?"
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2039
msgid ""
"I need 525 gold to pay Gaelyn. If you help me with that, I will come fight "
"with you."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2043
msgid "Are you interested?"
msgstr ""

#. [option]
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2045
msgid "Sure, here is the gold."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2070
msgid ""
"At your service. Just tell me where we go, and I will do what I can so that "
"we arrive there alive."
msgstr ""

#. [message], speaker=narrator
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2083
msgid ""
"Is is a hero. Heroes, of whom you will soon have a collection, will always be"
" recalled automatically. Heroes can pick up and equip items. Once recruited, "
"they will provide you with an additional unit type to recruit. If a hero "
"dies, you won't be able to recruit this unit type anymore."
msgstr ""

#. [message], speaker=narrator
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2089
#: ./Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1904
msgid "You can now recruit bowmen."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2095
msgid ""
"I appreciate the trust you place in me, but I need to pay my debts before "
"everything. Come back when you have the gold."
msgstr ""

#. [message], speaker=Is
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2106
msgid "You never know, right? If you change your mind, you know where to find me."
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2161
msgid ""
"The divine fire is in you my child. Your destiny might incline you to "
"accomplish great things, but let's begin by dealing with the most urgent "
"matters first."
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2176
msgid ""
"If you need potions, I can sell you useful ones and at low price. Do you want"
" to see them?"
msgstr ""

#. [option]
#: ./Legends_of_Idaamub/scenarios/chapter2/06_Zei.cfg:2178
#: ./Legends_of_Idaamub/scenarios/chapter2/11_Qyizu.cfg:1335
#: ./Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1496
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:599
