#. [message], speaker=Io
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:969
msgid "Let's look for a way out and hope it takes us closer to our goal."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter5\35b_Flooded_Tunnels.cfg:975
