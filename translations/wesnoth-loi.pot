#. [message], speaker=unit
#: .\scenarios\chapter4\33_Goblins_Lair.cfg:1966
#: .\scenarios\chapter4\33_Goblins_Lair.cfg:2020
#: .\scenarios\chapter4\33_Goblins_Lair.cfg:2053
msgid "The bridge turned."
