msgid "Old Temple"
msgstr ""

#. [objective], condition=win
#: .\scenarios\chapter5\37_Old_Temple.cfg:27
msgid "Cross the old temple"
msgstr ""

#. [objective], condition=win
#: .\scenarios\chapter5\37_Old_Temple.cfg:32
msgid "Defeat both enemy leaders"
