#. [message], speaker=unit
#: ./Legends_of_Idaamub/utils/deaths.cfg:361
#: ./Legends_of_Idaamub/utils/deaths.cfg:457
msgid "It is better that we split."
msgstr ""

#. [message], speaker=unit
#: ./Legends_of_Idaamub/utils/deaths.cfg:399
