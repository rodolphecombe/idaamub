#: .\scenarios\chapter4\33_Goblins_Lair.cfg:1646
#: .\scenarios\chapter4\34_Hive.cfg:949
#: .\scenarios\chapter4\34_Hive.cfg:975
#: .\scenarios\chapter4\34_Hive.cfg:1016
#: .\scenarios\chapter4\34_Hive.cfg:1049
