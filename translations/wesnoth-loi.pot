#. [message], speaker=unit
#: .\scenarios\chapter4\33_Goblins_Lair.cfg:1710
#: .\scenarios\chapter4\33_Goblins_Lair.cfg:1753
#: .\scenarios\chapter4\34_Hive.cfg:1090
