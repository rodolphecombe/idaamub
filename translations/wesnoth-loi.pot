#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:55
msgid "Find more information."
msgstr ""

#. [objective], condition=win
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:65
