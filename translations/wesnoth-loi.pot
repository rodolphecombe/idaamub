#: .\scenarios\chapter3\20_Ice_Cave.cfg:4
msgid "Ice_Cave"
msgstr ""

#. [objective], condition=win
#: .\scenarios\chapter3\20_Ice_Cave.cfg:51
#: .\scenarios\chapter3\22_Ice_Prison.cfg:30
msgid "Find Teumiuxe"
msgstr ""

#. [objective], condition=win
#: .\scenarios\chapter3\20_Ice_Cave.cfg:62
msgid "Defeat the enemy leader before going east"
msgstr ""

#. [side], type=Ice Guard LoI
#. [side], type=Ice Swordsman LoI
#. [side], type=Frozen Lich LoI
#. [side], type=Ice Bat LoI
#: .\scenarios\chapter3\20_Ice_Cave.cfg:106
#: .\scenarios\chapter3\20_Ice_Cave.cfg:123
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:85
#: .\scenarios\chapter3\22_Ice_Prison.cfg:74
msgid "Ice Beings"
msgstr ""

#. [side], type=Ice Troll Shaman LoI
#. [side], type=Ice Bat LoI
#. [side], type=Troll Warrior
#. [side], type=Troll Hero
#. [side], type=Troll Boulderlobber
#. [side], type=Troll Rocklobber
#: .\scenarios\chapter3\20_Ice_Cave.cfg:517
#: .\scenarios\chapter3\22_Ice_Prison.cfg:390
#: .\scenarios\chapter4\23_Abxoowbus_Trading_Post.cfg:190
#: .\scenarios\chapter4\25_Troll_Cave.cfg:76
#: .\scenarios\chapter4\26b_Troll_Fort.cfg:92
#: .\scenarios\chapter4\26_Echo_Chamber.cfg:73
#: .\scenarios\chapter4\27_Saurian_Pond.cfg:181
#: .\scenarios\chapter4\28_Travelers.cfg:92
#: .\scenarios\chapter4\29_Black_Forest.cfg:89
msgid "Trolls"
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:631
msgid "Look! Here it is."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:635
msgid "The Ice Cave. We have finally found it."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:639
msgid "Now we need to enter and find Teumiuxe."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:649
msgid "Wait a minute. Has this block of ice moved?"
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:659
msgid "It did it again. This isn't your average everyday block of ice."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:663
msgid "This is, advanced block of ice. It looks a bit like a Swordsman."
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\20_Ice_Cave.cfg:672
msgid "Marvelous!"
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\20_Ice_Cave.cfg:676
msgid ""
"This ice cave must have created this being out of ice and magic. It must have"
" imitate the beings that cross it."
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\20_Ice_Cave.cfg:680
msgid "I wonder what other kind of creatures we will find in there."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:684
msgid "How are you so enthusiast about everything?"
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:705
msgid "The door opened when I approched."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:716
msgid "Let's see what's in there."
msgstr ""

#. [message], speaker=$opener.id
#: .\scenarios\chapter3\20_Ice_Cave.cfg:765
msgid "I think I just saw this flying piece of ice come out a block of ice."
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\20_Ice_Cave.cfg:774
msgid "You all don't realize! It should not even be possible!"
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\20_Ice_Cave.cfg:778
msgid "These ice bats are too heavy to fly. Only magic can make they fly."
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\20_Ice_Cave.cfg:782
msgid "I love this place."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:803
#: .\scenarios\chapter3\20_Ice_Cave.cfg:828
msgid "It looks like I stepped on some mechanism."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:832
msgid "Look what I found."
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\20_Ice_Cave.cfg:848
msgid ""
"South-west : Udxatfe\n"
"North-east : Abxoowbu’s trading post"
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:866
msgid "There is a breeze coming from east."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:870
msgid ""
"If this tunnel goes around the main force, we would be able to either dodge "
"it or attacked it from behind."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:906
msgid "I feel a great amount of magic east. This might be Teumiuxe."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:916
msgid ""
"It would be good to kill whoever is sending all those ice beings at us before"
" going further. Otherwise we might have to fight two battles at once."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:924
msgid ""
"I'm glad that we killed the Ice Guard. Otherwise we might have had to fight "
"two battles at once."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:948
msgid "This cave is bigger than I thought. And still no sign of Teumiuxe."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:952
msgid "I did not expect him to be held prisoner right at the entrance, but still."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:958
msgid ""
"This cave is bigger than I thought. But we now have an hint on where Teumiuxe"
" is."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:962
msgid ""
"It's not like we were expecting him to be held prisoner right at the entrance"
" anyway."
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:979
msgid "Look other there. There is a treasure in an alcove"
msgstr ""

#. [message], speaker=unit
#: .\scenarios\chapter3\20_Ice_Cave.cfg:986
msgid "Maybe it was the treasure gathered by the ice beings."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:1006
msgid "This cave is bigger than I thought. And still now sign of Teumiuxe."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:1010
msgid "It is getting too difficult with all those ice beings coming at us."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\20_Ice_Cave.cfg:1014
msgid "Let's go back to Udxatfe to ask for help."
msgstr ""

#. [scenario], id=21_Frozen_Chasm
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:4
msgid "Frozen Chasm"
msgstr ""

#. [objective], condition=win
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:31
msgid "Defeat who is corrupting the magic"
msgstr ""

#. [objective], condition=win
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:41
msgid "Defeat the transformed lich"
msgstr ""

#. [message], speaker=Lujeje
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:182
msgid ""
"Someone is corrupting the magic for his own deed. Be careful everyone, dark "
"magic is at play."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:188
msgid ""
"I am shivering. But not only from cold. It is as if someone was stepping on "
"my grave."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:194
msgid "Be careful everyone. I don't think we will like what is lying further."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:213
#: .\scenarios\chapter4\26_Echo_Chamber.cfg:526
msgid "Aaaaaaahhhh!"
msgstr ""

#. [1]
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:217
#: .\scenarios\chapter4\26_Echo_Chamber.cfg:530
msgid "Oh my god! He fell in a crevasse."
msgstr ""

#. [message], speaker=Lich
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:229
msgid "Fools. I am one with the cave."
msgstr ""

#. [message], speaker=Lich
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:233
msgid "I will resurrect as one of them and there is nothing you can do about that."
msgstr ""

#. [message], speaker=Transformed Lich
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:263
msgid "Noooooooooooooooooo..."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\21_Frozen_Chasm.cfg:267
msgid "Well, looks like the path is cleared. Let's continue."
msgstr ""

#. [scenario], id=22_Ice_Prison
#: .\scenarios\chapter3\22_Ice_Prison.cfg:4
msgid "Ice_Prison"
msgstr ""

#. [side]
#: .\scenarios\chapter3\22_Ice_Prison.cfg:426
msgid "Teumiuxe"
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:456
msgid ""
"I heard a wing flapping. But it does not sound like the ones of these ice "
"bats."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:460
msgid "I wonder what other kind of creature awaits us in this cave."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:464
msgid ""
"I hope we will find Teumiuxe soon, before being killed by some unexpected ice"
" thing."
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:479
msgid ""
"North: Udxatfe \n"
"South: Abxoowbu’s trading post"
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:575
msgid "What to say?"
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:581
msgid ""
"I'm Teumiuxe, the great mage of the 10th legion, third in line for the "
"throne."
msgstr ""

#. [option]
#: .\scenarios\chapter3\22_Ice_Prison.cfg:592
msgid "What are you doing here ?"
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:596
msgid "I’ve been hanging for… "
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:600
msgid "How much… "
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:604
msgid "A bit less than a month."
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:608
msgid "Nearly a month, now? This is surprising! "
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:612
msgid ""
"The power of the ice trolls has really grown. I should have paid more "
"attention to them. "
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:616
msgid "Damn, I should have seen that coming!"
msgstr ""

#. [option]
#: .\scenarios\chapter3\22_Ice_Prison.cfg:627
msgid "Do you know what happened while you were prisoner?"
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:631
msgid "Tell me."
msgstr ""

#. [message], speaker=Csia
#: .\scenarios\chapter3\22_Ice_Prison.cfg:640
msgid ""
"Orcs are pillaging the High Arable Lands as well as the surroundings of Zei. "
"Zei has been attacked and pillaged too."
msgstr ""

#. [message], speaker=Csia
#: .\scenarios\chapter3\22_Ice_Prison.cfg:644
msgid ""
"Someone taught the orcs how to animate the dead and ancient threats are "
"awakening."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:650
msgid ""
"Orcs are pillaging the High Arable Lands as well the surroundings of Zei. Zei"
" has been attacked and pillaged too."
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:654
msgid ""
"Someone taught the orcs how to animate the dead and there are human-sized "
"spiders in Uvju's cross."
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:660
msgid "Those responsible of this violence are looking for my protection staff. "
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:664
msgid "Your staff?! "
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:668
msgid "Yes, this is what they are interested in. "
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:672
msgid "Is this what they were looking for in Zei?"
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:676
msgid ""
"Probably. They think it has powers it hasn’t, but it remains a terrible "
"weapon in the wrong hands. "
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:680
msgid "It must be found back!"
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:695
msgid ""
"I’m still too weak to go get my protection staff by myself but, if you help "
"me, we should be able to find it together. Will you?"
msgstr ""

#. [option]
#: .\scenarios\chapter3\22_Ice_Prison.cfg:697
msgid "Of course. How could we refuse your help?"
msgstr ""

#. [message], speaker=Teumiuxe
#. [message], speaker=Eukhac
#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:718
#: .\scenarios\chapter4\28_Travelers.cfg:1919
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1121
msgid "I am sorry, but you seem to be quite a party already."
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:735
msgid "This is a good choice. Let’s end the mess I started."
msgstr ""

#. [option]
#: .\scenarios\chapter3\22_Ice_Prison.cfg:746
msgid "You'd better go back to safety to Udxatfe. We will find it for you."
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:750
msgid "Don’t you see what is happening? The fate of the whole kingdom is at stake."
msgstr ""

#. [message], speaker=Teumiuxe
#: .\scenarios\chapter3\22_Ice_Prison.cfg:754
msgid ""
"If you don’t have the guts to help me save all these people, I’ll find "
"someone who do."
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:774
msgid ""
"The great mage having succeeded in freeing himself from its ice grave, it is "
"clear now that a maleficent spirit manipulates the forces rampaging the "
"kingdom."
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:778
msgid "Our heroes went looking for clues on the hide of the protection staff."
msgstr ""

#. [message], speaker=narrator
#: .\scenarios\chapter3\22_Ice_Prison.cfg:782
msgid "TO BE CONTINUED"
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:796
msgid "Still no trace of Teumiuxe. "
msgstr ""

#. [message], speaker=Io
#: .\scenarios\chapter3\22_Ice_Prison.cfg:800
msgid "I'm afraid we have to go back to Udxatfe to announce that we failed... "
msgstr ""

