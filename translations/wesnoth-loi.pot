#: ./Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:116
#: ./Legends_of_Idaamub/scenarios/chapter5/36_Old_Temple_Road.cfg:74
msgid "Wildlife"
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:370
msgid "Finally! We are out of this freezing cave."
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:374
msgid "Not that it is especially warmer outside."
msgstr ""

#. [message], speaker=Teumiuxe
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:383
msgid "I know a merchant that lives a bit south from here."
msgstr ""

#. [message], speaker=Teumiuxe
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:387
msgid "Well, not really a merchant. Let's call him a trapper."
msgstr ""

#. [message], speaker=Teumiuxe
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:391
msgid "He also sells things that he finds in the surrounding woods, or so he says."
msgstr ""

#. [message], speaker=Teumiuxe
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:395
msgid ""
"But he has his ways to collect valuable pieces of information. If he is "
"willing to, he might gives us some insight on where my staff might be."
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:401
msgid "Let's explore a bit the forest. We might find someone knowing something. "
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:405
msgid ""
"I don't expect to find the location of the staff, but maybe someone will have"
" heard something about a magic artifact. "
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:411
msgid ""
"The forest looks quite dense. I am afraid we won't be able to get through the"
" woods if the relief is too hilly."
msgstr ""

#. [message], speaker=unit
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:442
msgid "Argh! I'm burning! The chest was trapped."
msgstr ""

#. [message], speaker=Teumiuxe
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:461
msgid "Hello Abxoowbu, how are you?"
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:465
msgid ""
"Hi mage. It has been a long time since I've last seen you there. What are you"
" doing here?"
msgstr ""

#. [message], speaker=Teumiuxe
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:469
msgid "Have you heard anything about a special staff or a magic artifact?"
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:473
msgid "Well, I did not think you could fall so low. "
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:479
msgid ""
"Excuse me, my brave. Would you happen to have heard anything about a special "
"staff or a magic artifact?"
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:483
msgid "Who are YOU? One more minion of this nasty little goblin? "
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:489
msgid ""
"Tell this greenish guttersnipe that I don’t have his precious staff and never"
" had it."
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:493
msgid ""
"I don’t deal exotic items and even if I had had such a staff, there is no way"
" I would go deep into the eastern swamp to sell it to a mother of stranger."
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:497
msgid "Hurry up telling me what you want before I kick your behind back to the snow."
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:501
msgid "Well at least we got some information."
msgstr ""

#. [message]
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:514
msgid "Hmmm... the Eastern Swamp. This is south."
msgstr ""

#. [message]
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:518
msgid "This means we have to cross the trolls cave."
msgstr ""

#. [message]
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:522
msgid ""
"But I had no idea that goblins were living in the swamp. However, he might be"
" the one that has the staff."
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:528
msgid "The Eastern Swamp... I think it is south."
msgstr ""

#. [message], speaker=Io
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:537
msgid "Would you anyway agree to trade with us?"
msgstr ""

#. [message], speaker=trader
#: ./Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:575
msgid ""
"You’re as welcome as a sconce in a bunch of flowers if you wanna know. What "
"does your brainless boss want today?"
msgstr ""

