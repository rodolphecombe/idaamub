#: Legends_of_Idaamub/utils/item_list.cfg:15483
msgid "Optimistic hamstring-cutter of tears"
msgstr "Cortador de tendones optimista de lágrimas"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:15503
