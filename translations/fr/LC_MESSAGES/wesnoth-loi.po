#. [message], speaker=Io
#: .\utils\global_events.cfg:308
msgid "We have no more way to transport our food, we need to find a replacement as soon as possible, or we won't be able to carry enough food for everyone."
msgstr "On n'a plus rien pour transporter notre nourriture, on doit trouver quelque chose au plus vite, ou on ne pourra pas transporter de la nourriture pour tout le monde. "

#. [objective], condition=win
#: .\utils\global_events.cfg:512
#: .\utils\global_events.cfg:538
