#. [object]
#: .\utils\item_list.cfg:7346
msgid "Staff of shivering"
msgstr "Bâton de grelottement"

#. [object]
#: .\utils\item_list.cfg:7359
msgid "Even in summer my ice doesn't melt."
msgstr "Même en été, ma glace ne fond pas."

#. [object]
#: .\utils\item_list.cfg:7362
msgid "Staff of the fox"
msgstr "Bâton du renard"

#. [object]
#: .\utils\item_list.cfg:7375
msgid ""
"<span color='green'>Damage increased by 48%</span>\n"
"<span color='orange'>Max HP increased by 14 HP.</span>"
msgstr ""
"<span color='green'>Dégâts augmentés de 48%</span>\n"
"<span color='orange'>+14 HP max</span>"

