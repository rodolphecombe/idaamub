"<span color='blue'>PX máximos disminuidos en 6 PX.</span>"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:15449
msgid "Be audacious yet flexible."
msgstr "Sé audaz pero flexible."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:15452
msgid "Ripper symptomatic steel sword"
msgstr "Espada de acero sintomática destripadora"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:15462
msgid "Well the brothers go rip dung riot on the whole bloody place."
msgstr "Bueno, los hermanos van a destripar un motín de estiércol en todo el maldito lugar."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:15465
msgid "Assault ripper axe of outburst"
msgstr "Hacha de asalto destripadora de estallido"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:15476
msgid ""
"Split me open\n"
"With devotion\n"
"You put your hands in\n"
"And rip my heart out\n"
"Eat the music."
msgstr ""
"Ábreme en dos\n"
"Con devoción\n"
"Pones tus manos adentro\n"
"Y arrancas mi corazón\n"
"Come la música."

