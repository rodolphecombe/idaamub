#: Legends_of_Idaamub/utils/item_list.cfg:7361
msgid "Many foxes grow grey, but few grow good."
msgstr "Muchos zorros se vuelven grises, pero pocos se vuelven buenos."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7364
msgid "Slippery bow of the parasite"
msgstr "Arco resbaladizo del parásito"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7377
msgid "Your policies regarding orcs appear to be on a slippery slope that could take us toward war in Idaamub."
msgstr "Sus políticas respecto a orcos parecen estar en una pendiente resbaladiza que podría llevarnos hacia la guerra en Idaamub."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7380
msgid "Haste bow"
msgstr "Arco de prisa"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7390
msgid "Festina lente."
msgstr "Festina lente."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7406
msgid "Allow to recruit Skeletons"
msgstr "Permet de recruter des Squelettes"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7407
msgid "Because we had seven skeletons I thought we were going to get seven certificates"
msgstr "Porque teníamos siete esqueletos pensé que íbamos a obtener siete certificados"

