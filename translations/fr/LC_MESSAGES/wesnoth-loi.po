msgstr "Guantes de brigandina sin rasguños"

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7567
msgid "Keep unscratched an image of upheaval."
msgstr "Mantengan sin rasguños una imagen de upheaval."

#. [object]
#: Legends_of_Idaamub/utils/item_list.cfg:7580
