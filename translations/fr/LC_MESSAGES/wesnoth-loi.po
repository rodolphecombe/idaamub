msgid ""
"<span color='green'>Damage increased by 48%</span>\n"
"<span color='orange'>Max HP increased by 14 HP.</span>"
msgstr ""
"<span color='green'>Daño aumentado en 48%</span>\n"
"<span color='orange'>PV máx. aumentados en 14 PV.</span>"

