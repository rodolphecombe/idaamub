msgstr "Ballesta larga de granjero"

#. [object]
#: .\utils\item_list.cfg:11080
msgid "Curved halberd"
msgstr "Alabarda curva"

#. [object]
#: .\utils\item_list.cfg:11092
msgid "Infallible brillant curved crossbow"
msgstr "Ballesta curva brillante infalible"

#. [object]
#: .\utils\item_list.cfg:11116
msgid "This crossbow has to be thought of as infallible."
msgstr "Esta ballesta debe pensarse como infalible."

#. [object]
#: .\utils\item_list.cfg:11119
msgid " Cruel optimistic halberd of promise"
msgstr "Alabarda cruel optimista de promesa"

