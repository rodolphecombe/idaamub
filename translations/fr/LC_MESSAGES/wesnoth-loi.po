#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1136
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1195
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1254
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1301
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1348
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1408
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1476
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:181
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:586
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:645
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:712
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:789
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:848
msgid "No, it's too dangerous. You'll get killed."
msgstr "Non, c'est trop dangereux. Vous allez vous faire tuer."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1034
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1094
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1154
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1214
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1274
msgid "The explosion opened a hole in the wall."
msgstr "L'explosion a ouvert un trou dans le mur. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1313
msgid "What's this room?"
msgstr "Quel est cet endroit ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1317
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1327
msgid "This is where we repair the carts."
msgstr "C'est là que nous réparons les chariots."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1321
msgid "That explains all the tracks."
msgstr "Ça explique toutes les voies."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1354
msgid "I think I found the elevator."
msgstr "Je crois que j'ai trouvé l'ascenseur."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1383
msgid "We don't have the time to fight rats. Let's go down."
msgstr "Nous n'avons pas le temps de nous battre contre les rats. Descendons."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1395
msgid "The rats are dead. Let's go down."
msgstr "Les rats sont morts. Descendons."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1416
msgid "Wait for us! We are still fighting the rats here!"
msgstr "Attendez-nous ! On se bat encore contre les rats ici !"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1442
msgid "Too many rats. We can't fight them and the orcs. We will have to find another way."
msgstr "Trop de rats. On ne peut pas se battre contre eux et les orcs. On va devoir trouver un autre chemin."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1448
msgid "Too many orcs. We will never be able to reach Hufifa nor the exit of the mine."
msgstr "Trop d'orcs. On n'arrivera pas à atteindre Hufifa ou la sortie de la mine."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1462
msgid "The king of the rats is dead. Now, let's destroy the nest."
msgstr "Le roi des rats est mort. Maintenant, détruisons le nid."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1491
msgid "That's it. The rats should not bother us anymore."
msgstr "Voilà. Les rats ne devraient plus nous embêter."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1497
msgid "That's it. The rats should not bother the dwarves anymore."
msgstr "Voilà. Les rats ne devraient plus embêter les nains. "

#. [scenario], id=13_Miners_Life
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:6
msgid "Miners Life"
msgstr "La Vie de Mineur"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:52
msgid "Clean the dwarvish living quarters."
msgstr "Nettoyer les quartiers d'habitation des nains."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:708
msgid "Wow! It looks like there's a little welcoming commitee waiting for us. "
msgstr "Wahou ! On dirait qu'il y a un petit comité d'accueil qui nous attends."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:789
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1131
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1190
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1249
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:176
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:581
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:640
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:707
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:766
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:843
msgid "It opened a hole in the wall."
msgstr "Ça a ouvert un trou dans le mur."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:831
msgid "The zone is cleared."
msgstr "La zone est nettoyée."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:835
msgid "So, Amin, tell us. Which way should we go?"
msgstr "Dites-nous, Amin. On va de quel côté ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:839
msgid "The next elevator is north-west."
msgstr "Le prochain ascenseur est au nord-ouest."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:872
msgid "Look over there. This a mine worm. They dig galleries in the mine."
msgstr "Regardez par ici. C'est un ver des mines. Ils creusent des galeries dans les mines."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:876
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:904
msgid "Be careful not to get hurt. They shoot poisonous stings."
msgstr "Faites attention à ne pas être blessé. Ces choses crachent des dards venimeux. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:880
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:908
msgid "Life in the mines seems really dangerous."
msgstr "La vie dans les mines semble vraiment dangereuse."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:884
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:912
msgid "You don't say?"
msgstr "N'est-ce pas ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:890
msgid "What's this monstrosity?"
msgstr "Qu'est-ce que c'est que cette monstruosité ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:900
msgid "This a mine worm. They dig galleries in the mine."
msgstr "C'est un ver des mines. Ils creusent des galeries dans les mines."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:918
msgid "It looks like a big worm."
msgstr "On dirait un gros ver."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:927
msgid "It went back into its hole. Who knows where it will reappear?"
msgstr "Il est reparti dans son trou. Qui sait où il va réapparaitre ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:947
msgid "There is a teleporting rune on the floor."
msgstr "Il y a une rune de téléportation sur le sol. "

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:951
msgid "It teleports the one walking on it somewhere else."
msgstr "Elle téléporte qui marche dessus quelque part ailleurs."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:955
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1014
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1056
msgid "I didn't know the dwarves possess this kind of knowledge."
msgstr "Je ne savais pas que les nains possédaient ce genre de savoir."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:965
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1018
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1066
msgid "We don't. Those were already here."
msgstr "Ce n'est pas le cas. Elles étaient déjà là."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:969
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1022
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1070
msgid "The demons must have placed them then. Are they safe?"
msgstr "Les démons ont dû les placer dans ce cas. Sont-elles sûres ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:973
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1026
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1074
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1114
msgid "Well, we are using them on a daily basis, so I would say they are. The only problem is that you never know what's on the other side in advance."
msgstr "Et bien, nous les utilisons tous les jours, donc je dirais qu'elles le sont. Le seul problème c'est que vous ne savez jamais ce qu'il y a de l'autre côté à l'avance."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:977
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1030
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1078
msgid "I heard rumors of people merging with other beings inappropriately standing on the receiving rune. But this one seems to have a protection against that."
msgstr "J'ai entendu des rumeurs de gens fusionnant avec d'autres êtres qui se trouvaient malencontreusement sur la rune d'arrivée. Mais on dirait que celle là a une protection contre ça."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:981
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1034
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1082
msgid "Yes, they don't work if someone is standing on the other side."
msgstr "Oui, elles ne fonctionnent pas s'il y a quelqu'un de l'autre côté. "

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:987
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1088
msgid "This isn't safe magic. I heard rumors of people merging with other beings inappropriately standing on the receiving rune. "
msgstr "Ce n'est pas une magie sûre. J'ai entendu des rumeurs de gens fusionnant avec d'autres êtres qui se trouvaient malencontreusement sur la rune d'arrivée."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:991
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1092
msgid "But this one seems to have a protection against that."
msgstr "Mais on dirait que celle là a une protection contre ça."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1000
msgid "Look over there. This rune on the floor is a teleporting rune."
msgstr "Regardez par ici. Cette rune sur le sol est une rune de téléportation."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1004
msgid "It teleports the one walking on it to another rune further in the mine."
msgstr "Elle téléporte qui marche dessus vers une autre rune plus loin dans la mine."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1042
msgid "There is a rune drawn on the floor. What could it be?"
msgstr "Il y a une rune dessinée au sol. Qu'est-ce que ce pourrait être ?"

#. [message], speaker=Lujeje
#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1052
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1106
msgid "It is a teleporting rune. It teleports the one walking on it somewhere else."
msgstr "C'est une rune de téléportation. Elle téléporte qui marche dessus autre part."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1110
msgid "Isn't it dangerous?"
msgstr "C'est dangereux ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1118
msgid "But they don't work if someone is standing on the other side. I don't want to know what would happen otherwise."
msgstr "Mais elle ne fonctionne pas s'il y a quelqu'un de l'autre côté. Je ne veux pas savoir ce qui se passerait dans le cas contraire."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1124
msgid "I'm afraid I have no knowledge about that. We need a volunteer to stand on it."
msgstr "J'ai bien peur de n'en avoir aucune idée. On a besoin d'un volontaire pour monter dessus."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1128
msgid "Be careful. We have no idea what might happen."
msgstr "Faites attention. On n'a aucune idée de ce qu'il pourrait se passer."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1160
#: Legends_of_Idaamub/scenarios/chapter5/37_Old_Temple.cfg:514
msgid "Oh oh."
msgstr "Oh oh."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1189
msgid "The living quarters of the mine are behind this door."
msgstr "Les quartiers d'habitation de la mine sont derrière cette porte."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1195
msgid "Should I try to open the door?"
msgstr "J'ouvre la porte ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1220
msgid "Well, it looks like they are full of orcs."
msgstr "Et bien, on dirait qu'ils sont pleins d'orcs. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1224
msgid "How are we supposed to get back to work if we cannot live in here?"
msgstr "Comment sommes nous supposés retourner au travail si on ne peut pas habiter ici ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1228
msgid "You would do us a great favor if you could get rid of those orcs. The elevator is'nt far from here so we can go down right after you are done."
msgstr "Vous nous feriez une grande faveur en nous débarassant de ces orcs. L'ascenseur n'est pas très loin d'ici alors nous pourrons descendre dès que vous aurez terminé."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1262
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1306
msgid "There is a large metal door. Should I try to open it?"
msgstr "Il y a une grande porte en métal. Je l'ouvre?"

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1357
msgid "The living quarters are cleared. Your friends can come back to mine."
msgstr "Les quartiers d'habitations sont nettoyés. Vos amis peuvent revenir dans la mine. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1361
msgid "Thank you Io. Here, have some gold from our reserve to help you in your journey."
msgstr "Merci Io. Tenez, acceptez un peu d'or de notre réserve pour vous aider dans votre voyage."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1365
msgid "Thank you Amin."
msgstr "Merci Amin."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1374
msgid "Well, it looks like the elevator won't go down."
msgstr "Et bien, on dirait que l'ascenseur ne veut pas descendre. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1378
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1441
msgid "Something must be blocking the mechanism down there. There are other elevators further north."
msgstr "Quelque chose doit bloquer le mécanisme en bas. Il y a d'autres ascenseurs plus au nord."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1409
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1502
msgid "I think I found an elevator."
msgstr "Je crois que j'ai trouvé un ascenseur."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1447
msgid "It looks like the mine continues further north. Let's go this way."
msgstr "On dirait que la mine continue au nord. Allons par là."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:1474
msgid "Too many orcs and no way to go down. We will never be able to reach Hufifa nor the exit of the mine."
msgstr "Trop d'orcs et aucun moyen de descendre. On n'arrivera jamais à atteindre Hufifa ou la sortie de la mine."

#. [scenario], id=14_Mine_Maze
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:4
msgid "Mine Maze"
msgstr "Labyrinthe Minier"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:40
msgid "Find your way through the mine."
msgstr "Trouver votre chemin à travers la mine."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:45
msgid "Defeat both orcish leaders."
msgstr "Vaincre les deux chefs orcs."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:882
msgid "I don't really know the part lying further."
msgstr "Je ne connais pas vraiment cette partie là. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:886
msgid "It has been abandoned a long time ago as it is full of scorpions, mine worms and stone golems."
msgstr "Elle a été abandonnée il y a longtemps car elle est pleine de scorpions, de vers des mines et de golems de pierre."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:890
msgid "I think we can add orcs to the list now."
msgstr "Je crois qu'on peut ajouter les orcs à la liste maintenant. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:894
msgid "Aye, I'm afraid so."
msgstr "Ouep, j'en ai bien peur."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:898
msgid "Anyway, my brother is down here as is the way to Udxatfe."
msgstr "Dans tous les cas, mon frère est en bas, ainsi que le chemin pour Udxatfe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:904
msgid "Still no sign of Hufifa or the exit."
msgstr "Toujours aucun signe d'Hufifa ou de la sortie."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:908
msgid "I hope the mine doesn't go any deeper."
msgstr "J'espère que la mine ne descend pas plus profondement. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:912
msgid "Anyway, we don't have much other choice. Let's go."
msgstr "Dans tous les cas, on n'a pas le choix. Allons-y. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:928
msgid "It looks like there is another teleporting rune on the floor."
msgstr "Il semblerait qu'il y ait une autre rune de téléportation au sol. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:947
msgid "Oh oh..."
msgstr "Oh oh..."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:975
msgid "It looks like the orc built a settlement here."
msgstr "Il semblerait que les orcs aient bati un camp ici. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:984
msgid "If you can get rid of it, it would allow us dwarves to come back to mine this area."
msgstr "Si vous pouviez vous en débarrasser, cela permettrait à nous les nains de revenir miner par ici. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:990
msgid "If we can get rid of it, it would allow the dwarves to come back to this area."
msgstr "Si on peut s'en débarasser, ça permettra aux nains de revenir par ici."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1015
msgid "Thanks to you, us dwarves will be able to come back to mine this area."
msgstr "Grâce à vous, nous les nains pourrons revenir miner par ici."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1019
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1033
msgid "It looks like the orcs had gathered some treasures in the mines."
msgstr "Il semblerait que les orcs aient rassemblés des trésors dans les mines. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1023
msgid "Please take it as a mark of appreciation for helping us."
msgstr "Prenez-les en gage de remerciant pour nous avoir aider."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1029
msgid "Now the dwarves should be able to come back to mine this area."
msgstr "Maintenant les nains devraient pouvoir revenir miner par ici."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1037
msgid "We should leave it to the dwarves, but we also need gold for our journey."
msgstr "On devrait les laisser aux nains, mais on a aussi besoin d'or pour notre voyage."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1041
msgid "Please take half of it and leave a message for the dwarves to apologize."
msgstr "Prenez-en la moitié et laissez un message d'excuse aux nains."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1051
msgid "We have two choices here. Either we can go down that elevator or we can continue north."
msgstr "On a deux choix. Soit on descend avec l'ascenseur, soit on continue vers le nord."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1053
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1526
msgid "Go down."
msgstr "Descendre"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1066
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1539
msgid "Go north."
msgstr "Aller au nord."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1371
msgid "There're three barrels full of powder. Should I light them up?"
msgstr "Il y a trois barils de poudre. Je les allume ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1373
msgid "Yes but be careful not to get killed. The combined blast will be powerful."
msgstr "Oui mais faites attention à ne pas vous faire tuer. L'explosion combinée sera très puissante."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1568
msgid "Scorpions, ghosts, mine worms, all that on top of the orcs. We won't go further with that much enemies."
msgstr "Des scoprions, des fantômes, des vers de mine, tout ça en plus de sorcs. On n'ira pas plus loin avec autant d'ennemis."

#. [scenario], id=14b_Down_the_Elevator
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:4
msgid "Down the Elevator"
msgstr "En Bas de l'Ascenseur"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:27
msgid "Search the level."
msgstr "Fouiller le niveau."

#. [side], type=Stone Golem
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:68
msgid "monsters"
msgstr "Monstres"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:125
msgid "Well, it looks like we have a little welcoming comitee."
msgstr "Et bien, on dirait qu'il y a un petit comité d'accueil qui nous attends."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:207
msgid "I think I found the other elevator. It doesn't look like this tunnel goes further."
msgstr "Je crois que j'ai trouvé l'autre ascenseur. On dirait que le tunnel ne va pas plus loin."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:229
msgid "Let's go back up"
msgstr "Remontons. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:241
msgid "Wait for us. We're almost done."
msgstr "Attendez-nous. On a presque fini."

#. [scenario], id=15_Ups_and_Downs
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:4
msgid "Ups and Downs"
msgstr "Des Hauts et des Bas"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:40
msgid "Exit the mine."
msgstr "Sortir de la mine."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:51
msgid "Find Hufifa before leaving."
msgstr "Trouver Hufifa avant de partir."

#. [side], type=Orcish Ruler
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:94
msgid "Orcs 1"
msgstr "Orcs 1"

#. [side], type=Orcish Ruler
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:129
msgid "Orcs 2"
msgstr "Orcs 2"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:367
msgid "There we are. Back up again."
msgstr "Et voilà. De retour en haut."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:379
msgid "I think I recognize this part of the mine. The elevator to the surface should be north."
msgstr "Je crois que je reconnais cette partie de la mine. L'ascenseur pour la surface devrait être au nord."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:383
msgid "We only need to find my brother and then you will be able to continue your quest."
msgstr "Nous avons juste besoin de trouver mon frère et après vous pourrez continuer votre quête."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:387
msgid "I'm sorry Amin, but your brother is not our priority. We can try to find him, but we are not even sure he is still in the mine."
msgstr "Je suis désolé Amin, mais votre frère n'est pas notre priorité. On va essayer de le trouver, mais on n'est même pas sûr qu'il soit toujours dans la mine."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:391
msgid "If we don't find him quickly, we will have to leave without him."
msgstr "Si on ne le trouve pas rapidement, il faudra partir sans lui."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:397
msgid "I have no idea where we are. And still no sign of Hufifa."
msgstr "Je n'ai aucune idée d'où nous sommes. Et toujours aucun signe d'Hufifa. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:401
msgid "But I can sense some fresh air. The exit should not be far."
msgstr "Mais je sens de l'air frais. La sortie ne devrait pas être loin."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:405
msgid "I would like to help those dwarves, but we can't spend more time in this mine."
msgstr "J'aimerais bien aider ces nains, mais on ne peut pas perdre plus de temps dans cette mine."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:430
msgid "Hufifa! My Brother! We found you!"
msgstr "Hufifa ! Mon frère ! Nous t'avons trouvé !"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:434
msgid "Aye! Well done, brother!"
msgstr "Ouep ! Bien joué, frérot !"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:440
msgid "Are you Hufifa?"
msgstr "Êtes-vous Hufifa?"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:444
msgid "Of course I am! Have you heard of another dwarf kidnapped by those damn orcs?"
msgstr "Bien sûr que je le suis ! Vous avez entendu parler d'un autre nain enlevé par ces maudits orcs ?"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:448
msgid "Anyway, well done!"
msgstr "En tout cas, bien joué !"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:454
msgid "Those losers weren’t really any threat, but I would bet my mine that someone is pulling the strings behind them!"
msgstr "Ces perdants n'étaient pas vraiment une menace, mais je parierais ma mine que quelqu'un tire les ficelles derrière !"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:458
msgid "The guardian of Udxatfe must be warned, and quickly! If you go that way, I would be grateful if you could warn everyone."
msgstr "Le gardien d'Udxatfe doit être prévenu, et rapidement ! Si vous allez dans cette direction, je vous serais reconnaissant de prévenir tout le monde."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:462
msgid "What if he doesn't believe us?"
msgstr "Et s'il ne nous croit pas ?"

#. [message], speaker=Csia
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:472
msgid "He knows me. I should be enough of a proof that our story is true."
msgstr "Il me connaît. Je devrais être une preuve suffisante que notre histoire est vraie."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:476
msgid "Anyway, take that."
msgstr "Dans tous les cas, prenez ça."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:481
msgid "It's my lucky-charm. That’s the least I can do, after all you’ve done for me. "
msgstr "C'est mon porte-bonheur. C'est le moins que je puisse faire, après tout ce que vous avez fait pour moi."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:487
msgid "If the guardian gives you troubles, show him my lucky-charm and he will know that I’m sending you."
msgstr "Si le gardien vous embête, montrez-lui mon porte-bonheur et il saura que je vous envoie."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:491
msgid "You can even keep it. Take."
msgstr "Vous pouvez même le garder. Tenez."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:496
msgid "That’s the least I can do, after all you’ve done for me."
msgstr "C'est le minimum que je peux faire, après tout ce que vous avez fait pour moi."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:502
msgid "Won't you come with us?"
msgstr "Vous ne venez pas avec nous ?"

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:506
msgid "I would, but I’ve got to put my guys back to work, now that you’ve cleaned up. "
msgstr "Je le ferai mais je dois remettre mes gars au boulot, maintenant que vous avez nettoyé."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:510
msgid "Waste no time, warn the guardian of Udxatfe as quickly as possible! We will cope without you."
msgstr "Ne perdez pas de temps, prévenez le gardien d'Uxatfe aussi vite que possible ! Je me débrouillerai sans vous."

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:520
msgid "Brother, go with them. They will need your help."
msgstr "Frérot, vas avec eux. Ils auront besoin de ton aide."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:524
msgid "Aye, brother. Take care of the mine while I'm away."
msgstr "Oui frérot. Prend soin de la mine pendant que je suis au loin. "

#. [message], speaker=Hufifa
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:528
msgid "As if I ever needed you to take care of the mine. Try not to get killed."
msgstr "Comme si j'avais jamais eu besoin de toi pour m'occuper de la mine. Essayes de ne pas te faire tuer."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:784
msgid "And something is not happy about this."
msgstr "Et ça ne fait pas plaisir à quelque chose."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:865
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1032
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1244
msgid "There's a lever to make the elevator go down. Do you want to pull it?"
msgstr "Il y a un levier pour faire descendre l'ascenseur. Je le tire ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:867
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1034
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1246
msgid "Yes, let's go down."
msgstr "Oui, on descend."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:943
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1017
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1086
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1155
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1229
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1303
#: Legends_of_Idaamub/scenarios/chapter5/35b_Flooded_Tunnels.cfg:2932
msgid "No, not yet."
msgstr "Non, pas maintenant."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:958
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1101
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1170
msgid "There's a lever to make the elevator go up. Do you want to pull it?"
msgstr "Il y a un levier pour faire monter l'ascenseur. Je le tire ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:960
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1103
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1172
msgid "Yes, let's go up."
msgstr "Oui, on monte."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1331
msgid "The elevator to the surface is behind that door."
msgstr "L'ascenseur pour la surface est derrière cette porte."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1335
msgid "Should I try to open it?"
msgstr "Je l'ouvre?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1362
msgid "There is a huge metal door. Should I try to open it?"
msgstr "Il y a une grande porte en métal. Je l'ouvre?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1381
msgid "There is an elevator behind it."
msgstr "Il y a un ascenseur de l'autre côté."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1385
msgid "I see light up there. It must be the elevator to the surface."
msgstr "Je vois de la lumière là-haut. Ce doit être l'ascenseur pour la surface."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1427
msgid "I'm sorry Amin, but we don't have the time to find your brother."
msgstr "Je suis désolé Amin, mais nous n'avons pas le temps de chercher votre frère. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1431
msgid "Well, I don't have the time to help you either! I will stay here and find my brother."
msgstr "Et bien, je n'ai pas le temps de vous aider non plus ! Je vais rester ici et trouver mon frère."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1455
msgid "You can now longer recruit nor recall Dwarvish Fighters."
msgstr "Vous ne pouvez plus recruter ou rappeller des Combattants Nains."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1461
msgid "It is a bit sad that we did not find the dwarf, but we don't have the time to search for him."
msgstr "C'est un peu triste qu'on n'ait pas trouvé le nain, mais on n'a pas le temps de le chercher."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1475
msgid "Hufifa is safe. We can now leave the mine without any regret."
msgstr "Hufifa est sauf. On peut quitter la mine sans regret maintenant. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1485
msgid "My brother gave me a bit of gold that he had hidden from the orcs, to help us in our journey."
msgstr "Mon frère m'a donnée un peu d'or qu'il avait caché des orcs, pour nous aider dans notre voyage."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1489
msgid "That's very nice of him."
msgstr "C'est très gentil de sa part."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1511
msgid "Wait for us! We will try to find Hufifa before leaving."
msgstr "Attendez-nous ! On va essayer de trouver Hufifa avant de partir."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:1532
msgid "We can't find Hufifa, nor the exit. We will probably die in this mine."
msgstr "On n'arrive à trouver ni Hufifa ni la sortie. On va probablement mourir dans cette mine."

#. [scenario], id=16_Snow_Wizards
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:4
msgid "Snow Wizards"
msgstr "Magiciens des Neiges"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:40
msgid "Reach Udxatfe."
msgstr "Atteindre Udxatfe"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:51
msgid "Defeat all enemy leaders before reaching Udxatfe"
msgstr "Vaincre tous les chefs ennemis avant d'atteindre Udxatfe"

#. [side], type=Ice Troll LoI
#. [side], type=Ice Troll Warrior LoI
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:94
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:82
#: Legends_of_Idaamub/scenarios/chapter3/18b_Frozen_Cave.cfg:95
#: Legends_of_Idaamub/scenarios/chapter3/19_Frozen_Maze.cfg:107
msgid "Ice Trolls"
msgstr "Trolls des Glaces"

#. [side], type=Great Wolf
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:135
msgid "Wolves"
msgstr "Loups"

#. [side], type=Ogre
#. [side], type=Great Ogre
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:242
#: Legends_of_Idaamub/scenarios/chapter4/29_Black_Forest.cfg:178
msgid "Ogres"
msgstr "Ogres"

#. [side], type=Swordsman
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:268
msgid "Guards"
msgstr "Gardes"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:315
msgid "Finally, we are back to the surface."
msgstr "Enfin, on est de retour à la surface."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:325
msgid "I'm glad we found Hufifa down there. Every bit of good we can do is good to take."
msgstr "Je suis content qu'on ait trouver Hufifa là en bas. Chaque bonne action qu'on peut faire est bonne à prendre."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:335
msgid "Thank you for helping me find my brother. He'd tell otherwise, but he wouldn't have survived if we hadn't found him."
msgstr "Merci de m'avoir aider à trouver mon frère. Il dirait le contraire, mais il n'aurait pas survécu si nous ne l'avions pas trouvé."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:343
msgid "I'm sad we didn't find Hufifa down there. It feels wrong leaving someone to die behind."
msgstr "Je suis triste qu'on ait pas trouvé là en bas. Je n'aime pas laisser quelqu'un pour mort derrière nous. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:350
msgid "It looks like we arrived in a chalet in the middle of the snow."
msgstr "On dirait qu'on est arrivé dans un chalet au milieu de la neige."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:354
msgid "That's why we don't really trade with Udxatfe. We prefer the warmth of our mine to the cold of Udxatfe's weather. "
msgstr "C'est pour cela que nous ne commerçons pas avec Udxatfe. Nous préférons le chaud de nos mines au froid du climat d'Udxatfe."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:358
msgid "With all this snow, we shouldn't be far from Udxatfe. It marks out the border with the freezing North."
msgstr "Avec toute cette neige, nous ne devrions pas être loin d'Udxatfe. Elle marque la frontière avec le nord glacé."

#. [message]
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:362
msgid "I don't think we will find more orcs further. I don't remember them liking cold weather."
msgstr "Je ne pense pas qu'on trouvera des orcs plus loin. Je ne me souviens pas qu'ils aiment le froid."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:366
msgid "Let's find Udxatfe and deliver our message."
msgstr "Trouvons Udxatfe et livrons notre message."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:381
msgid ""
"West: Qyizu’s Mine. \n"
"South: Udxatfe"
msgstr ""
"Ouest : Mine de Qyizu \n"
"Sud : Udxatfe"

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:400
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:436
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:454
msgid "East: Udxatfe"
msgstr "Est : Udxatfe"

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:418
msgid "North: Udxatfe"
msgstr "Nord : Udxatfe"

#. [message], speaker=Innec
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:471
msgid "Never had I seen wolves attacking an armed group. Something has probably made them nervous."
msgstr "Je n'avais jamais vu des loups attaquer un groupe armé. Quelque chose les a probablement rendus nerveux. "

#. [message], speaker=Addthynaent
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:491
msgid "Welcome stranger."
msgstr "Bienvenue étranger."

#. [message], speaker=Addthynaent
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:495
msgid "The Guardian wishes to see all those coming from the south. Sorry, Legion’s order."
msgstr "Le Gardien souhaite voir tout ceux qui arrivent du sud. Désolé, ordre de la Légion. "

#. [message], speaker=Addthynaent
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:499
msgid "You will certainly find him at the Blessed Uaja’s Inn."
msgstr "Vous le trouverez certainement à l'Auberge de la Sainte Uaja."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:525
#: Legends_of_Idaamub/scenarios/chapter4/25_Troll_Cave.cfg:578
msgid "Wait for us! We are still fighting the trolls here!"
msgstr "Attendez nous ! On est encore en train de combattre les trolls ici !"

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:548
msgid "What's this? It looks like some kind of troll. "
msgstr "Qu'est-ce donc ? Cela ressemble à une sorte de troll. "

#. [message]
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:552
msgid "It's an Ice Troll."
msgstr "C'est un Troll des Glaces."

#. [message]
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:556
msgid "They are trolls that have adapted to cold weathers. The good thing is that they fear fire."
msgstr "Ce sont des trolls qui se sont adaptés au climat froid. Le bon côté, c'est qu'ils ont peur du feu."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:560
msgid "It doesn't look very happy finding us on its territory."
msgstr "Il n'a pa très l'air content de nous trouver sur son territoire."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:570
msgid "I'm afraid we will have to fight to reach Udxatfe."
msgstr "J'ai bien peur qu'on doive le combattre pour atteindre Udxatfe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:619
msgid "We should be alright now. Those were really strange beings."
msgstr "On devrait être tranquille maintenant. C'était vraiment des êtres étranges."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:629
msgid "So cold..."
msgstr "Tellement froid..."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:633
msgid "Feeling numb..."
msgstr "Me sent engourdi..."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/16_Snow_Wizards.cfg:637
msgid "Must not..."
msgstr "Dois pas..."

#. [scenario], id=17_Udxatfe
#. [side], type=Lieutenant
#. [side], type=Swordsman
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:4
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:139
#: Legends_of_Idaamub/scenarios/chapter3/18_In_the_Snow.cfg:202
msgid "Udxatfe"
msgstr "Udxatfe"

#. [part]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:32
msgid "Our hero emerged from remote lands to bring the Guardian a warning, exuding a fortified spirit, ready to endure the hard tasks to come."
msgstr "Notre héros émergea des terres lointaines pour porter au Gardien un avertissement, exhalant un esprit fortifié, prêt à endurer les dures tâches à venir."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:72
msgid "Talk to the Guardian."
msgstr "Parler au Gardien"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:82
msgid "Leave Udxatfe."
msgstr "Quitter Udxatfe."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:93
msgid "Find the two remaining books."
msgstr "Trouvez les deux livres restants"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:104
msgid "Find Roiwv, Owreddoc's sister."
msgstr "Trouver Roiwv, la sœur d'Owreddoc."

#. [side], type=Ice Troll Hero LoI
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:379
msgid "Ice trolls"
msgstr "Trolls des glaces"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:420
msgid ""
"Finally, Udaxtfe. I am glad to be there.\n"
"Now, let's find the guardian."
msgstr ""
"Enfin, Udxatfe. Je suis content d'y être. \n"
"Maintenant, trouvons le gardien."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:435
msgid "I hate this watchtower. I could swear this old statue is watching me."
msgstr "Je déteste cette tour de garde. Je pourrais jurer que cette vieille statue me regarde."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:439
msgid "It is said it was already there when the first colonists arrived."
msgstr "On dit qu'elle était déjà là quand les premiers colons sont arrivés."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:453
msgid "Excuse me, may I ask you what you’re doing here?"
msgstr "Excusez-moi, puis-je vous demander ce que vous faites ici ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:455
msgid "Nothing"
msgstr "Rien"

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:459
msgid "Bye then."
msgstr "Au revoir alors."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:474
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2632
msgid "We are looking for a book."
msgstr "Nous sommes à la recherche d'un livre."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:478
msgid "Oh! I see, you’re reading one of those Oa’s books."
msgstr "Oh ! Je vois, vous lisez un de ces livres d'Oa."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:482
msgid "Those are fine reading! I finished this one."
msgstr "Ce sont de saines lectures ! J'ai fini celui-là."

#. [message], speaker=Vonin
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:486
msgid "I can lend it to you but don’t forget to bring it back to that mage child once you’re done."
msgstr "Je peux vous le prêter mais n'oubliez pas de le rapporter à l'enfant mage quand vous aurez fini."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:490
msgid "Sure. We'll bring it back."
msgstr "Bien sûr. Nous le rapporterons."

#. [message], speaker=Tinthynaent
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:508
msgid "You seem to have had your share of suffering, pal."
msgstr "Vous semblez avoir eu votre lot de souffrance, l'ami."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:512
msgid "We sure did."
msgstr "Pour sûr."

#. [message], speaker=Tinthynaent
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:516
msgid "With a bit of luck, these counterattacks the guardian prepares will give me something to tell my grand-children."
msgstr "Avec un peu de chance, ces contre-attaque que le gardien prépare me donnera quelque chose à raconter à mes petits-enfants."

#. [message], speaker=Cytharry
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:530
msgid "If you came to Udxatfe to shelter, you made the right choice."
msgstr "Si vous êtes venu à Udxatfe pour vous abriter, vous avez fait le bon choix."

#. [message], speaker=Cytharry
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:534
msgid "The guardian called all the patrols up here to counterattack."
msgstr "Le gardien à rappellé toutes les patrouilles ici pour contre-attaquer."

#. [message], speaker=Cytharry
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:538
msgid "Nowhere else will you see that many legionaries, except at Oof’s fortress or Idaamub’s castle."
msgstr "Nulle part ailleurs vous ne verrez autant de légionnaires, sauf à la forteresse d'Oof et au château d'Idaamub."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:552
msgid "It looks like you're mad at someone."
msgstr "Il semblerait que vous soyez en colère contre quelqu'un. "

#. [message], speaker=Addogyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:557
msgid "Damn men! My uncle’d rather listen to those morons from the legion than believe his own niece!."
msgstr "Maudits hommes ! Mon oncle préfère écouter ces abrutis de la légion plutôt que sa propre nièce."

#. [message], speaker=Addogyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:562
msgid "And yet, I saw Teumiuxe the mage in a dream, a prisoner in the ice caves to the north."
msgstr "Et pourtant, j'ai vu Teumiuxe le mage en rêve, prisonnier dans les grottes de glace au nord."

#. [message], speaker=Addogyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:567
msgid "For generations, my whole family has had this gift, to see things in their dreams."
msgstr "Depuis des générations, ma famille a eu ce don, voir des choses en rêve."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:571
msgid "You could become a heroin with this kind of gift."
msgstr "Vous pourriez devenir une héroïne avec ce don. "

#. [message], speaker=Addogyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:576
msgid "The problem is that for now my quest sums up to doing the cleaning and the cooking. And working behind the counter, of course! "
msgstr "Le problème, c'est que pour l'instant ma quête consiste en le ménage et la cuisine. Et travailler derrière le comptoir bein sûr."

#. [message], speaker=Addogyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:581
msgid "Wretched life!"
msgstr "Chienne de vie !"

#. [message], speaker=Vugwylyn
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:595
msgid "My only wish is to get back to Zei, but the guardian told me the road was dangerous this week."
msgstr "Mon seul souhait est de rentrer à Zei mais le gardien m'a dit que la route était dangereuse cette semaine."

#. [message], speaker=Innoc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:609
msgid "The guardian seems determined to mobilize all our military strength west of Udxatfe, while captain Soimaql must fight the Dunefolk with only one troop of men."
msgstr "Le gardien semble déterminé à mobiliser toute notre force militaire à l'ouset d'Udxatfe, pendant que le capitaine Soimaql doit se battre contre les Ammorites avec une seule troupe d'hommes."

#. [message], speaker=Innoc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:613
msgid "Soimaql is brilliant, but still! We haven't fought the Dunefolk for centuries."
msgstr "Soimaql est brillant mais quand même ! Nous n'avons pas combattu les Ammorites depuis des siècles."

#. [message], speaker=Innoc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:617
msgid " If they are as good soldiers as smiths, the war can last."
msgstr "S'ils sont aussi bon soldats que forgerons, la guerre risque de durer."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:631
msgid "Orcs have always been opportunists and will always be. Yet, I don’t understand how goblins managed to excite them into their current madness."
msgstr "Les orcs ont toujours été opportunistes et ils le seront toujours. Cependant, je ne comprend pas comment les gobelins ont réussi à les exciter jusqu'à leur folie actuelle."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:635
msgid "There must be another explanation behind all these inexplicable occurrences."
msgstr "Il doit y avoir une autre explication derrière ces faits inexplicables."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:639
msgid "Have you spoken to Addogyc?"
msgstr "Vous avez parlé à Addogyc?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:641
msgid "Yes"
msgstr "Oui"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:644
msgid "No"
msgstr "Non"

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:648
msgid "She says Teumiuxe the mage is prisoner in the ice caves."
msgstr "Elle dit que Teumiuxe le mage est prisonnier dans les grottes de glace."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:655
msgid "If her information are true, we are hugely indebted to her. The guardian will have to replan our next move."
msgstr "Si ses informations sont vraies, nous avons une immense dette envers elle.Le gardien devra replanifier notre prochain coup."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:659
msgid "What do you think he should do?"
msgstr "Que pensez-vous que nous devrions faire ?"

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:663
msgid "If the mage Teumiuxe is a prisoner of the goblins, we should waste no time; we must leave as quickly as possible, go to the swamp in the East, and search for him in their fortress."
msgstr "Si le mage Teumiuxe est prisonnier des gobelins, nous ne devons pas perdre de temps; nous devons partir au plus vite, aller au marais à l'est et le chercher dans leur forteresse."

#. [message], speaker=Aenyc
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:693
msgid "Sure, how much do you need?"
msgstr "Bien sûr, vous en voulez combien ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:812
msgid "Excuse me. Do you happen to be the Guardian?"
msgstr "Excusez-moi. Seriez-vous par hasard le Gardien?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:840
msgid "Report the warning"
msgstr "Rapporter l'avertissement"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:853
msgid "Greetings. You are a long way from home."
msgstr "Salutations. Vous êtes bien loin de chez vous."

#. [message], speaker=Csia
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:857
msgid "Indeed. I am here to warn you that orcs attacked Zei and are roaming the land around."
msgstr "En effet. Je suis ici pour vous prévenir que les orcs ont attaqué Zei et sillonnent les terres alentours."

#. [message], speaker=Csia
#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:861
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:879
msgid "We had to fight our way to here."
msgstr "Nous avons dû nous battre jusqu'ici."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:865
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:883
msgid "By the dragon, it looks like I missed a nice fight."
msgstr "Par le dragon, on dirait que j'ai raté une belle bataille."

#. [message], speaker=Csia
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:869
msgid "Men have died!"
msgstr "Des hommes dont morts !"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:875
msgid "We come in behalf of Csia of Zei to warn you that orcs attacked the city and are roaming the land around."
msgstr "On vient de la part de Csia de Zei pour vous prévenir que les orcs ont attaqué la ville et sillonnent les terres alentours."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:887
msgid "Well... that's one way to see it..."
msgstr "Et bien... c'est une façon de la voir..."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:893
msgid "Ha! The legionaries are saying it is even worse on the other side of the mountain."
msgstr "Ha ! Les légionnaires disent que c'est encore pire de l'autre côté de la montagne. "

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:897
msgid "Dunefolk mounted archers are pillaging villages east and I heard orcish marauders are looking for some kind of magic artifact…"
msgstr "Les archers montés ammorites pillent les villages à l'est et j'ai entendu dire que des maraudeurs orcs cherchent une sorte d'artefact magique..."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:908
msgid "Find out what is happening"
msgstr "Découvrir ce qu'il se passe"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:912
msgid "Excuse me, what is happening here?"
msgstr "Excusez-moi, il se passe quoi ici ?"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:916
msgid "Everything began the day our great mage Teumiuxe disappeared and if you want my opinion, it’s not a coincidence!"
msgstr "Tout a commencé le jour où notre grand mage Teumiuxe a disparu, et, si vous voulez mon opinion, ce n'est pas une coïncidence."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:920
msgid "That mad innkeeper says she knows where he is, but I tell you he is dead or kept as a hostage at our little friend's from East."
msgstr "Cette folle d'aubergiste dit qu'elle sait où il est, mais je vais vous dire, il est soit mort, soit retenu en otage par nos petits amis de l'est. "

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:931
msgid "Propose your help"
msgstr "Proposer votre aide"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:941
msgid "Can we do something to help?"
msgstr "On peut faire quelque chose pour aider ?"

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:945
msgid "You seems like capable people."
msgstr "Vous semblez être des gens capables."

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:949
msgid "I need someone to go east and find Teumiuxe, dead or alive."
msgstr "J'ai beosin que quelqu'un aille à l'est et trouve Teumiuxe, mort ou vif. "

#. [message], speaker=Guardian
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:953
msgid "Find him and you’ll find at the same time the reason for this mess!"
msgstr "Trouvez-le et vous trouverez en même temps la raison de ce bazar !"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1005
msgid "Me Uwiu. Strong warrior."
msgstr "Moi Uwiu. Guerrier fort. "

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1020
msgid "Chief tell Uwiu bring caravan Idaamub’s kingdom."
msgstr "Chef dire Uwiu amener caravane royaume d'Idaamub."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1024
msgid "Uwiu bring Zei and stupid orcs burn city!"
msgstr "Uwiu apporter Zei et stupides orcs brûler ville !"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1028
msgid "Driver steal wagon, steal gold Uwiu and flee."
msgstr "Conducteur voler chariot, voler or Uwiu et fuir."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1032
msgid "Uwiu follow to Udxatfe but can’t go further."
msgstr "Uwiu suivre jusqu'à Udxatfe mais peut pas aller plus loin. "

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1043
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1251
msgid "We are looking for some strong recruit for our group. Are you interested?"
msgstr "Nous sommes à la recherche de quelqu'un de fort pour notre groupe. Êtes-vous intéressé ?"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1051
msgid "Uwiu help you if you help him. Uwiu need 1700 gold."
msgstr "Uwiu aide vous si vous aider lui. Uwiu besoin 1700 or."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1055
msgid "Uwiu good to strike, hit, break…"
msgstr "Uwiu bon à frapper, taper, casser..."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1059
msgid "Everything and everyone!"
msgstr "Tout et tout le monde ! "

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1063
msgid "You OK?"
msgstr "Vous d'accord ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1065
msgid "We OK."
msgstr "Nous d'accord."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1075
msgid "Not enough gold."
msgstr "Pas assez d'or."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1079
msgid "Uwiu need gold or no go back home."
msgstr "Uwiu besoin or ou pas rentrer maison."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1100
msgid "Ah-ah! You make perfect choice! Excellent!"
msgstr "Ha-ha ! Vous faire excellent choix ! Excellent !"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1104
msgid "We have fun a lot hit orcs, save kingdom!"
msgstr "Nous prendre beaucoup plaisir taper orcs, sauver royaume ! "

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1108
msgid "You can now recruit thugs."
msgstr "Vous pouvez maintenant recruter des brutes."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1115
msgid "Sorry, we not enough gold."
msgstr "Désolé, nous pas assez or."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1119
msgid "You think about that."
msgstr "Vous pensez à ça."

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1123
msgid "Uwiu wait, stay here for when you want strong warrior, OK?"
msgstr "Uwiu attend, reste ici pour quand vous vouloir fort guerrier, d'accord ?"

#. [message], speaker=Uwiu
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1127
msgid "Well. well. See you later."
msgstr "Bien. Bien. A plus tard."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1179
msgid "I'm Asaem, a mage."
msgstr "Je suis Aseam, un mage."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1183
msgid "I’m the best mage around. I might be a bit decrepit, but my fireballs were already grilling goblins when your grandfather was still wearing diapers."
msgstr "Je suis le meilleur mage alentour. Je suis peut-être un peu décrépi, mais mes boules de feu grillaient déjà des gobelins quand votre grand-père portait encore des couches."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1198
msgid "I was in a quest with other adventurers, but it went poorly."
msgstr "J'effectuais une quête avec d'autres aventuriers, mais cela s'est mal passé."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1202
msgid "<span font='italic'>Starts singing</span>"
msgstr "<span font='italic'>Commence à chanter</span>"

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1206
msgid "In this inn where we met, I bumped into 5 to 6 soldiers. At least 4 wanted to hit me. Instead they trampled my black cat."
msgstr "Dans cette auberge où l'on s'est rencontré, cinq, six soldats j'ai bousculé. Yen a bien quatre qui voulaient m'frapper. C'est mon chat noir qu'ils ont piétiné."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1210
msgid "If I had known this spell, it never would have happened. If I had known this spell, unfortunately I had forgotten it."
msgstr "Si j’avais su ce sortilège, jamais ça ne serait arrivé. Si j’avais su ce sortilège, malheureusement je l’avais oublié."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1214
msgid "We arrived at the dungeon door, I wanted to try to lockpick it. Then a trap triggered, and the rogue got killed."
msgstr "Arrivée à la porte du donjon, j’ai voulu tenter d’ la crocheter. C’est là qu’un piège s’est déclenché. C’est le voleur qui a été tué."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1218
msgid "If I had had my scroll, I could have detected it. If I had had my scroll, but it was covered all over with wine stains."
msgstr "Si j’avais eu mon parchemin, j’aurais bien pu le détecter. Si j’avais eu mon parchemin, mais il est couvert partout de taches de vin."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1222
msgid "In the first corridor we were exploring, a herd of orcs arrived. I cast a fireball at them. But the dwarf received it."
msgstr "Dans le premier couloir on avançait, un troupeau d’orques est arrivé. Une boule de feu je leur ai lancée, mais c’est le nain qui se l’est ramassée."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1226
msgid "If I had had this old book, I would probably have aimed better. If I had had this old book, the one I lost the evening before."
msgstr "Si j’avais eu ce vieux grimoire, j’aurais sans doute mieux visé. Si j’avais eu ce vieux grimoire, celui que j’ai paumé avant-hier au soir."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1230
msgid "In the cellar that we escaped, we thought we were safe. Then we ran into a troll, of course the elf got eaten."
msgstr "C’est dans les caves qu’on s’est échappé, on pensait être en sécurité. C’est sur un troll qu’on est tombé, c’est bien sûr l’elfe qui s’est fait becqueter."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1234
msgid "If I had grabbed my wand, I could have petrified it. If I had grabbed my wand. I did not because it was in pieces."
msgstr "Si j’avais saisi ma baguette, elle aurait pu le pétrifier. Si j’avais saisi ma baguette, je ne l’ai pas fait car elle était en miettes."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1238
msgid "In the catacombs we were hiding in, I brushed against a huge bell. The dragon I awoke used the warrior as his breakfast."
msgstr "Dans les catacombes on était planqué, une énorme cloche j’ai effleurée. Le dragon que j’ai réveillé fit du guerrier son petit déjeuner."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1242
msgid "If I had had the One Ring, I would have crushed this dragon. If I had had the One Ring that was stolen one day from me by a hobbit."
msgstr "Si j’avais eu l’anneau unique, ce dragon j’ l’aurais bousillé. Si j’avais eu l’anneau unique, qui m’a été volé un jour par un hobbit."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1246
msgid "I am not sure if he is unsafe or just mad as a hatter."
msgstr "Je ne suis pas sûr s'il est dangereux, ou juste fou à lier. "

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1265
msgid "If the Guardian decided to give you an impossible quest, I need to give you at least a chance to stay alive."
msgstr "Si le Gardien a décidé de vous donner une quête impossible, je dois vous donner au moins une chance de rester en vie."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1271
msgid "I just need 1950 gold to pay my bill at the inn."
msgstr "J'ai juste besoin de 1950 d'or pour payer mon ardoise à l'auberge."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1275
msgid "If you have enough to pay my bill, we can go before you can say Jack Robinson."
msgstr "Si vous avez assez pour payer mon ardoise, nous pouvons  partir avant que vous n'ayez le temps de dire ouf."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1279
msgid "It's up to you."
msgstr "C'est vous qui voyez."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1281
msgid "Here is the gold."
msgstr "Voici l'or."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1291
msgid "I'm sorry, but there is not enough to pay my bill"
msgstr "Je suis désolé, mais il n'y a pas assez pour payer mon ardoise."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1312
msgid "Well. Then, let’s go."
msgstr "Bien. Alors, allons-y."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1316
#: Legends_of_Idaamub/scenarios/chapter3/22_Ice_Prison.cfg:739
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1151
msgid "You can now recruit mages."
msgstr "Vous pouvez maintenant recruter des mages."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1323
msgid "Sorry, we don't have that much gold to spend."
msgstr "Je suis désolé,nous n'avons pas autant d'or à dépenser."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1327
msgid "You’re quite reckless but do as you feel."
msgstr "Vous êtes plutôt téméraire, mais faites comme vous voulez."

#. [message], speaker=Asaem
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1331
msgid "I’ll be there when you’ll be back to your mind."
msgstr "Je serai ici quand vous serez revenu à la raison."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1361
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1379
msgid "Excuse me, do you know what is happening here?"
msgstr "Excusez-moi, savez-vous ce qu'il se passe ici ?"

#. [message], speaker=Aethyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1365
msgid "From what I heard, the Guardian requisitioned the patrols on duty along Oa’s gallery to have enough men to ensure the protection of Qyizu and Zei."
msgstr "De ce que j'ai entendu, le Gardien réquisitionne les patrouilles en poste le long de la galerie d'Oa pour avoir assez d'hommes pour assurer la protection de Qyizu et de Zei."

#. [message], speaker=Vobreorer
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1383
msgid "It is said the mystical seal of the queen’s men was seen here last week. "
msgstr "On dit que le sceau mystique des hommes de la reine a été vu ici la semaine dernière."

#. [message], speaker=Vobreorer
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1391
msgid "I asked the captain about that, and he extended my patrol by one week."
msgstr "J'ai posé la question au capitaine et il a rallongé ma patrouille d'une semaine."

#. [message], speaker=Vobreorer
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1395
msgid "But I still don’t know why everyone make such a mystery about this!"
msgstr "Mais je ne sais toujours pas pourquoi tout le monde fait un tel mystère à ce propos !"

#. [message], speaker=Rhyrthynaent
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1410
msgid "I’m sorry but we are not used to see so many legionaries on leave at the same time. Can you please stay here until a room is free?"
msgstr "Je suis désolé mais nous n'avons pas l'habitude de voir autant de légionnaires en permission en même temps. Pouvez-vous rester ici jusqu'à qu'une chambre ne se libère ?"

#. [message], speaker=Alyn
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1414
msgid "If the Guardian hadn’t called me back on his duty, I could sleep quietly in my bed instead of in this bloody corridor."
msgstr "Si le gardien ne m'avait pas rappellé sous son commandement, je pourrais dormir tranquillement dans mon lit plutôt que dans un de ces maudits couloirs. "

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1428
msgid "It’s quite cold, isn’t it?"
msgstr "Il fait plutôt froid, n'est-ce pas ?"

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1432
msgid "Gods be blessed, I don’t have to live here year long. I only come to do some experiments."
msgstr "Les dieux soient loués, je n'ai pas à vivre ici toute l'année. Je viens seulement pour faire quelques expériences."

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1436
msgid "Fire and ice spells, that kind of things."
msgstr "Des sorts de feu et de galce, ce genre de chose."

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1440
msgid "You see, I’ve a theory about that: if the spells work fine here, it should be the same anywhere else. Udxatfe has always been a special place where magic holds an important place! "
msgstr "Voyez-vous, j'ai une théorie à ce propos : si les osrts fonctionnent correctement ici, ce devrait être le cas partout ailleurs. Udxatfe a toujours été un endroit spécial où la magie détient une place importante. "

#. [message], speaker=Vugthynyr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1444
msgid "Probably because of the magic ice cave in the North."
msgstr "Probablement à cause de la grotte de glace magique au nord."

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1494
msgid "You can look at my potions and spells if you’re interested."
msgstr "Vous pouvez jeter un œil à mes potions et sorts si vous êtes interessés. "

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1546
#: Legends_of_Idaamub/utils/item_list.cfg:5421
msgid "A Dynamical Theory of the Electromagnetic Field"
msgstr "Une Théorie Dynamique du Champ Electromagnétique"

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1574
#: Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:1185
#: Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1574
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1888
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1824
msgid "Experience potion"
msgstr "Potion d'expérience"

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1575
#: Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:1186
#: Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1575
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1889
msgid "Healing potion"
msgstr "Potion de soin"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1576
#: Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:1187
#: Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:1576
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1825
#: Legends_of_Idaamub/utils/item_list.cfg:6042
msgid "Small potion of rejuvenation"
msgstr "Petite potion de jouvence"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1631
msgid "Excuse me"
msgstr "Excusez-moi"

#. [message], speaker=Teddthynec
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1635
msgid "Can't you see I'm busy?!"
msgstr "Vous ne voyez pas que je suis occupé ?!"

#. [message], speaker=Teddthynec
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1639
msgid "Someone troubled the spirit of the dead last week and now I need to provide them with fresh supplies."
msgstr "Quelqu'un a dérangé les esprits des morts la semaine dernière et maintenant je dois leut fournir des provisions fraîches."

#. [message], speaker=Teddthynec
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1643
msgid "If you need something, ask Vugthynyr. He is the one selling to the living this week."
msgstr "Si vous avez besoin de quelque chose, demandez à Vugthynyr. C'est lui qui vend aux vivants cette semaine."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1663
msgid "You seem worried. Can we help you?"
msgstr "Vous semblez inquiet. Pouvons-nous vous aider ?"

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1667
msgid "Master Vugthynyr gonna kill me!"
msgstr "Maître Vugthynyr va me tuer !"

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1671
msgid "I borrowed a trilogy of books about Oa’s gallery and gave them to two friends, but I forgot whom!"
msgstr "J'ai emprunté une trilogie de livres à propos de la galerie d'Oa et les ai donné à deux amis, mais je ne me souviens plus lesquels !"

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1675
msgid "Vugthynyr has forbidden me from leaving when he’s keeping the shop, but there’s no doubt he's gonna find out,… He'll find out any moment, that they’re gone."
msgstr "Vugthynyr m'a interdit de partir pendant qu'il tient la boutique, mais il n'y a aucun doute qu'il va le découvrir,... Il va se rendre compte à tout moment qu'ils ne sont plus là."

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1679
msgid "Could you please use a few minutes and enquire in town?"
msgstr "Pourriez-vous me donner quelques minutes de votre temps et vous renseigner en ville ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1681
msgid "Sure, we'll find them."
msgstr "Bien sûr, nous allons les trouver."

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1685
msgid "It’s very kind of you, stranger. I will gladly make up for the trouble."
msgstr "C'est très aimable à vous, étranger. Je vous compenserais avec plaisir pour le dérangement."

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1689
msgid "Here is one of the books, so you know exactly how they look."
msgstr "Voici un des livres, comme ça vous savez à quoi il ressemble. "

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1694
msgid "You receive an old book called ``Oa's gallery, volume 3''."
msgstr "Vous recevez un livre intitulé ``La galerie d'Oa, volume 3''."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1701
msgid "Sorry, we don't have the time for that."
msgstr "je suis désolé, nous n'avons pas le temps."

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1705
msgid "A-are you sure? Oh my! He really is gonna kill me!"
msgstr "V-vous êtes sûrs ? Oh mon dieu ! Il va me tuer !"

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1729
msgid "Thousand thanks, pal.  You allowed me to keep my job, and maybe my life."
msgstr "Merci mille fois, l'ami. Vous m'avez permis de garder mon travail et peut-être ma vie."

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1733
msgid "Accept this gold, this food and all my gratitude for your help."
msgstr "Acceptez cet or, cette nourriture et toute ma gratitude pour votre aide."

#. [message], speaker=Teoran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1747
msgid "Remember, I need the three books."
msgstr "Rappellez-vous, j'ai besoin des trois livres."

#. [message], speaker=narrator
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1767
msgid ""
"South: Zei, Qyizu’s mine\n"
"North-east: Alpine caves, Abxoowbu’s trading post"
msgstr ""
"Sud : Zei, mine de Qyizu\n"
"Nord-est : Grottes alpines, Comptoir commercial d'Abxoowbu"

#. [message], speaker=Derrreoryr
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1785
msgid "It’s been at least twenty years since we have last seen ogres around here."
msgstr "Cela fait au moins vingt ans que nous n'avions pas vu des ogres par ici."

#. [message], speaker=Marthynec
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1799
msgid "I swear on the welkin that I saw an ogre on my way from my guardhouse in the caves!"
msgstr "Je jure sur les cieux que j'ai vu un ogre en allant de ma caserne aux grottes ! "

#. [message], speaker=Gorcyn
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1813
msgid "Sarearan is the best blacksmith in the region. I’m glad he had the time to repair my armor with all those reservists of the Legion in town."
msgstr "Sarearan est le meilleur forgeron de la région. Je suis heureux qu'il ait eu le temps de réparer mon armure, avec tous ces réservistes de la Légion en ville."

#. [message], speaker=Ery
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1827
msgid "I needed this job at the blacksmith to pay for my room at the Blessed Uaja’s Inn ; my basement has become the lair of enormous frost monsters, and each time I opened the door of my house, a group of wolves swooped down on me!"
msgstr "J'avais besoin de ce boulot chez le forgeron pour payer ma chambre à l'auberge de la Sainte Uaja; ma cave est devenue le repaire d'énorme monstres de givre, et chaque fois que j'ouvrais la porte de ma maison, un groupe de loup me fondait dessus !"

#. [message], speaker=Ery
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1831
msgid "I don’t know when I’ll be able to go back, but Saraeran needs help and proposed to lend me his adventurer’s stuff if I keep working well during the Legion's demobilization."
msgstr "Je ne sais pas quand je pourrais y retourner, mais Sarearan a besoin d'aide et à proposer de mon prêter son matériel d'aventurier si je continue à bien travailler jusqu'à la démobilisation de la Légion."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1835
msgid "Maybe we can help you with that."
msgstr "Peut-être pouvons nous vous aider à ce sujet."

#. [message], speaker=Ery
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1840
msgid "Well, you look determined."
msgstr "Bon, vous avez l'air déterminé."

#. [message], speaker=Ery
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1844
msgid "You will find in the basement a chest and some crates. If you successfully get rid of the monsters prowling around, you can take what you want."
msgstr "Vous trouverez dans ma cave un coffre et quelques caisses. Si vous arrivez à vous débarasser des monstres qui grouillent autour, vous pourrez prendre ce que vous voulez."

#. [message], speaker=Ery
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1848
msgid "My house is in the woods, north-west of Udxatfe. I am afraid the path will be full of snow as I am not there to clean it."
msgstr "Ma maison est dans les bois, au nord-ouest d'Udxatfe. J'ai bien peur que le chemin soit envahi par la neige puisque je n'y suis pas pour le déblayer. "

#. [message], speaker=Seraeran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1862
msgid "Ah, young people, they all believe they will be able to save the world. "
msgstr "Ah, ces jeunes gens, ils croient tous pouvoir sauver le monde."

#. [message], speaker=Seraeran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1866
msgid "I had the same light in the eyes, before. I was not the last one to look for a fight, but I ended up by hanging my sword back up."
msgstr "J'avai la même lueur dans les yeux avant. Je n'était pas le dernier à chercher la bagarre, mais j'ai fini par raccrocher mon épée."

#. [message], speaker=Seraeran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1870
msgid "I can’t say this work is hard but well, you don’t see many people… Except for some time. "
msgstr "Je ne peux pas dire que ce métier est pénible mais bon, vous ne voyez pas beaucoup de monde... Sauf quelques fois."

#. [message], speaker=Seraeran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1874
msgid "Something bad is brewing. I feel it…"
msgstr "Quelque chose de mauvais se prépare. Je le sens..."

#. [message], speaker=Seraeran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1884
msgid "So, by the way, you’re leaving for the ice caves?"
msgstr "A propos, vous partez pour les grottes de glace ?"

#. [message], speaker=Seraeran
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1888
msgid "One must be wary of the slippery slopes. I advise you to equip yourselves for cold and climbing."
msgstr "Il faut faire attention aux pentes glissantes. Je vous conseille de vous équiper pour le froid et l'escalade."

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:1940
#: Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:689
msgid "Wanna see what I have in store?"
msgstr "Voulez-vous voir ce que j'ai en stock ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2045
#: Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:805
msgid "Polearms"
msgstr "Arme d'hast"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2150
#: Legends_of_Idaamub/utils/item_list.cfg:6423
msgid "Avenging burning staff"
msgstr "Bâton brulant vengeur."

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2151
#: Legends_of_Idaamub/utils/item_list.cfg:6545
msgid "Staff of power"
msgstr "Bâton de pouvoir"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2152
#: Legends_of_Idaamub/scenarios/chapter4/23_Abxoowbus_Trading_Post.cfg:821
#: Legends_of_Idaamub/scenarios/chapter4/28_Travelers.cfg:939
#: Legends_of_Idaamub/utils/item_list.cfg:6602
msgid "Avenging staff"
msgstr "Bâton vengeur"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter3/17_Udxatfe.cfg:2153
#: Legends_of_Idaamub/utils/item_list.cfg:6629
#: Legends_of_Idaamub/utils/item_list.cfg:8380
msgid "Staff of outburst"
msgstr "Bâton de déchaînement"

