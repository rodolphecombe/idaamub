#. [scenario], id=32_Eastern_Swamp
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:4
msgid "Eastern Swamp"
msgstr "Marais Oriental"

#. [side], type=Troll Warrior
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:79
msgid "Swamp Trolls"
msgstr "Trolls des Marais"

#. [side], type=Gobot Scorcher LoI
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:826
msgid "Gobots"
msgstr "Gobots"

#. [side]
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:843
msgid "Allies"
msgstr "Alliés"

#. [message], speaker=Io
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:898
msgid "Well, it's the last part of the swamp we have not searched. If we do not find the goblin's lair here, we will have to go back..."
msgstr "Bon, et bien, c'est le dernier coin du marais qu'on n'a pas encore fouillé. Si on ne trouve pas la tanière du gobelin ici, il faudra qu'on fasse demi-tour..."

#. [message], speaker=Io
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:902
msgid "If anyone notices anything out of place in this swamp, tell us. That might be the hint we are looking for."
msgstr "Si quelqu'un voit quoi que ce soit qui ne semble pas être à sa place dans ce marais, dites le. Ça sera peut-être l'indice qu'on cherche. "

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:917
msgid "Potions"
msgstr "Potions"

#. [message], speaker=unit
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:942
msgid "Aaaahhhh!!!"
msgstr "Aaaahhhh!!!"

#. [0]
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:970
msgid "We fell into a hole and into some kind of old temple. There seem to be Vine Tigers."
msgstr "Nous sommes tombés dans un trou et dans une sorte de vieux temple. On dirait qu'il y a des Tigres de Liane."

#. [message], speaker=unit
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:985
msgid "There's someone in the hut."
msgstr "Il y a quelqu'un dans la hutte."

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:991
msgid "Ah finally! I was starting to think all humans were gone. It looks like the country was invaded by monsters!"
msgstr "Ah, enfin! Je commençais à croire que tous les humains étaient partis. On dirait que la région est envahie par les monstres ! "

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1032
msgid "I'm Nrifyo, a young mage."
msgstr "Je suis Nrifyo, un jeune mage."

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1049
msgid "I arrived here following the trail of the gold pinched during Eukhac’s bowman tournament."
msgstr "Je suis arrivé ici en suivant la piste de l'or dérobé pendant le tournoi d'archerie d'Eukhac. "

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1076
msgid "Listen, I know I am young for a mage, but I know one or two spells and I’m ready to help you for a decent price. Let's say, 49000 gold."
msgstr "Ecoutez, je sais que je suis jeune pour un mage, mais je connais un ou deux sorts et je suis prêt à vous aider pour un prix décent. Disons, 49000 d'or."

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1082
msgid "Honestly, I know my job! I only need someone to watch my back."
msgstr "Honnêtement, je connais mon métier ! J'ai seulement besoin de quelqu'un pour surveiller mes arrières."

#. [option]
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1084
msgid "We would be glad to have you with us."
msgstr "Nous serions ravi de vous avoir avec nous."

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1096
msgid "I am afraid you don't have enough gold to hire me."
msgstr "j'ai bien peur que vous n'ayez pas assez d'or pour m'embaucher. "

#. [message], speaker=Nrifyo
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1147
msgid "By the stars, could have my luck changed? Nrifyo, mage apprentice, at your service!"
msgstr "Par les étoiles, ma chance aurait-elle tourné ? Nrifyo, apprenti mage, à votre service !"

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1167
msgid "Well… Yes, it was to be expected!"
msgstr "Et bien.. Oui, c'était à prévoir ! "

#. [message], speaker=narrator
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1173
msgid "I can’t see straight anymore, with all the hits my poor nut received, lately. See you around."
msgstr "Je ne vois plus bien droit, avec tous les coups que ma pauvre caboche a reçus, ces derniers temps. A la prochaine."

#. [message], speaker=unit
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1208
msgid "There's a witch in the hut."
msgstr "Il y a une sorcière dans la hutte."

#. [message], speaker=trader
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1219
msgid "Come in, come in! I won't hurt you."
msgstr "Entrez, entrez ! Je ne vais pas vous faire de mal. "

#. [message], speaker=trader
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1223
msgid "Oooh! Look at these beautiful men. Ain’t they magnificent in their suits? "
msgstr "Oooh ! Regardez-moi ces charmants jeunes hommes. Ne sont-ils pas magnifiques dans leurs costumes ?"

#. [message], speaker=trader
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1227
msgid "Admire their proud air. Their look neither bat nor falter. "
msgstr "Admirez leur air fier. Leur regard ne vacille pas."

#. [message], speaker=trader
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1231
msgid "But Meixmi knows how to catch their attention. She has a profusion of curative balms. "
msgstr "Mais Meixmi sait comment attirer leur attention. Elle a des baumes curatifs à profusion. "

#. [message], speaker=trader
#: .\scenarios\chapter4\32_Eastern_Swamp.cfg:1272
msgid "My potions are coming out of the caldron. Against a few coins, they will heal you."
msgstr "Mes potions sortent tout juste du chaudron. Contre quelques pièces, je vous soignerai."

