#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1162
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1221
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1279
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1326
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1454
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:148
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:553
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:612
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:671
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:738
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:815
msgid "Yes but be careful not to get killed."
msgstr "Oui mais faites attention à ne pas vous faire tuer. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:974
msgid "It cleared the rubble."
msgstr "Ça a nettoyé les débris."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:979
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1039
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1099
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1159
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1219
