#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1823
msgid "Agressive metal targe of the fox"
msgstr "Targe en métal agressive du renard"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1824
#: Legends_of_Idaamub/utils/item_list.cfg:11535
msgid "Unscratched wooden shield of inversion"
msgstr "Bouclier en bois intact d'inversion"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1825
#: Legends_of_Idaamub/utils/item_list.cfg:11554
msgid "Severe turtle shield of refuge"
msgstr "Bouclier tortue sévère de refuge"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1826
#: Legends_of_Idaamub/utils/item_list.cfg:11584
msgid "Negative wooden shield"
msgstr "Bouclier en bois négatif"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1854
#: Legends_of_Idaamub/utils/item_list.cfg:12065
msgid "Instant lightning"
msgstr "Eclair foudroyant"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1855
#: Legends_of_Idaamub/utils/item_list.cfg:12091
msgid "Sparkle rain"
msgstr "Pluie d'étincelles"

#. [message], speaker=trader
#. [object]
#. [abilities]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1856
#: Legends_of_Idaamub/utils/item_list.cfg:12126
#: Legends_of_Idaamub/utils/item_list.cfg:12137
msgid "Stone skin"
msgstr "Peau de pierre"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1857
#: Legends_of_Idaamub/utils/item_list.cfg:12143
msgid "Curse"
msgstr "Malédiction"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1858
#: Legends_of_Idaamub/utils/item_list.cfg:12171
msgid "Experience shield"
msgstr "Bouclier d'expérience"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1885
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1821
#: Legends_of_Idaamub/utils/item_list.cfg:12188
msgid "Great potion of rejuvenation"
msgstr "Grande potion de jouvence"

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:1886
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1822
msgid "Great experience potion"
msgstr "Grande potion d'expérience"

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2172
msgid "What's that? This definitely looks weirder that the rest."
msgstr "Qu'est-ce ? C'est définitivement plus bizarre que le reste."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2176
msgid "It looks like a dunefolk but made out of metal."
msgstr "Cela ressemble à un ammorite mais fait de métal."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2180
msgid "Bloody goblins. They keep stealing our technology and corrupting it."
msgstr "Maudits gobelins. Ils persistent à voler notre technologie et à la corrompre. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2184
msgid "Thank Of, this is the sign we were looking for. The lair's entrance should not be far."
msgstr "Of merci, c'est le signe qu'on attendait. L'entrée de la tanière ne doit pas être loin."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2197
msgid "There is a massive tree with a huge hole between its roots. It looks like there is a tunnel leading under it."
msgstr "Il y a un énorme arbre avec un gros trou entre les racines. Il semblerait qu'il y ait un tunnel qui mène en dessous."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2201
msgid "There seems to be an elevator under the tree."
msgstr "On dirait qu'il y a un ascenseur sous l'arbre."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2205
msgid "As I said, always stealing our technology."
msgstr "Comme je le disais, toujours à voler notre technologie."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2209
msgid "This must be the entrance! Let's go in there!"
msgstr "Ça doit être l'entrée ! Allons-y !"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2223
msgid "Well, no sign of a goblin. It was probably only a rumor."
msgstr "Et bien, toujours aucun signe d'un gobelin. Ce n'était probablement qu'une rumeur. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2227
msgid "I'm afraid we won't find Teumiuxe's staff in this swamp..."
msgstr "J'ai bien peur qu'on ne trouve pas le bâton de Teumiuxe dans ce marais..."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2267
#: Legends_of_Idaamub/scenarios/chapter4/32_Eastern_Swamp.cfg:2300
msgid "The house was full of trolls."
msgstr "La maison était pleine de trolls."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:25
msgid "There was an enemy hidden in this box."
msgstr "Il y avait un ennemi caché dans cette boite."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:59
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1607
msgid "The wall was actually a door. There is an enemy inside."
msgstr "Le mur était en fait une porte. Il y a un ennemi de l'autre côté."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:99
msgid "The wall was actually a door. There are enemies inside."
msgstr "Le mur était en fait une porte. Il y a des ennemis de l'autre côté."

#. [scenario], id=33_Goblins_Lair
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:108
msgid "Goblin's Lair"
msgstr "La Tanière des Gobelins"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:145
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:54
msgid "Find the protection staff"
msgstr "Trouver le bâton de protection"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:156
msgid "Kill all goblins"
msgstr "Tuer tous les gobelins"

#. [side], type=Goblin Chieftain
#. [side], type=Steel Skewer
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:200
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:98
msgid "Goblins"
msgstr "Gobelins"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1566
msgid "I would'nt've expected to find a cave like that under the swamp."
msgstr "Je ne me serais pas attendu à trouver une grotte comme ça sous le marais. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1570
msgid "That's because we are far underground. We passed the clay layer that is creating the swamp."
msgstr "C'est parce que nous sommes loin sous terre. Nous sommes passés sous la couche d'argile qui crée ce marais. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1574
msgid "The good news is that we found the goblins, which means the staff is hopefully not far."
msgstr "La bonne nouvelle c'est qu'on a trouvé les gobelins, ce qui veut dire que le bâton ne devrait pas être loin."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1578
msgid "The bad news is that we also found whatever that weird thing up there was. I'm afraid it might not be a one-of-a-kind."
msgstr "La mauvaise nouvelle, c'est qu'on a aussi trouvé ce que cette drôle de chose là-haut était. J'ai bien peur qu'il ne soit pas tout seul. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1582
msgid "The goblins seem to be working on them. They may be the ones assembling and reparing them."
msgstr "Les gobelins ont l'air de travailler dessus. Peut-être que c'est eux qui les assemblent et les réparent."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1602
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1624
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:931
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:995
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1020
msgid "There's a weird-looking orb here. Should I touch it?"
msgstr "Il y a une drôle d'orbe ici. Je la touche ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1612
msgid "It looks like it stopped the leak that was spitting fire on the bridge."
msgstr "Il semblerait que cela ait arrêté la fuite qui crachait du feu sur le pont."

#. [option]
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1617
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1643
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:946
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:972
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1013
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1046
msgid "No, who knows what it does."
msgstr "Non, qui sait ce que ça fait. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1638
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:967
msgid "The fire caused by the leak is back."
msgstr "Le feu causé par la fuite est de retour. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1669
msgid "It looks like there's a leak in a big pipe passing over the bridge that is causing a fire. We need to find a way to stop it if we don't want to burn going on the bridge."
msgstr "Il semblerait qu'il y ait une fuite dans un gros tuyau qui passe au dessus du pont, ce qui cause un feu. Nous devons trouver un moyen de l'arrêter si nous ne voulons pas brûler en passant sur le pont. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1707
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1750
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1087
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1130
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1172
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1215
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1257
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1300
msgid "Argh! I'm burning!"
msgstr "Argl ! Je brûle !"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1775
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1878
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2089
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2132
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2175
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2218
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2261
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2388
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2431
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1325
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1368
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1411
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1454
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1497
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1544
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1686
msgid "There's a huge metal door. Should I open it?"
msgstr "Il y a une grande porte en métal. Je l'ouvre ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1820
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2312
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2365
msgid "A machine came out of a trap."
msgstr "Une machine est sortie d'une trappe."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1853
msgid "Two machines came out of a trap."
msgstr "Deux machines sont sorties d'une trappe."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1963
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2017
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2050
msgid "The bridge turned."
msgstr "Le pont a tourné."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:1982
msgid "The door also opened."
msgstr "La porte s'est également ouverte."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2342
msgid "The wall was actually a door. There is something inside."
msgstr "Le mur était en fait une porte. Il y a quelque chose derrière."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2471
msgid "Look over there. This one looks a bit like a dwarf."
msgstr "Regardez. Celui-là ressemble à un nain. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2478
msgid "Kill it! Burn it! Destroy it!!!"
msgstr "Tuez le ! Brûlez le ! Détruisez le !!!"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2482
msgid "The whole place! Make it explode!!!"
msgstr "Tout l'endroit ! Faites le sauter !!!"

#. [message]
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2486
msgid "They look quite dangerous. It might be a good idea to kill the goblins servicing them to prevent them from being repaired."
msgstr "Ils ont l'air assez dangereux. Ce serait peut-être une bonne idée de tuer les gobelins qui les entretiennent pour les empêcher d'être réparés. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2512
msgid "Great... Another elevator..."
msgstr "Génial... Un autre ascenseur..."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2516
msgid "I assume this means that we need to go deeper to find the goblin leader. And the staff."
msgstr "J'imagine que cela veut dire que nous devons aller plus profond pour trouver le chef gobelin. Et le bâton. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2536
msgid "Let's go down. We need to find the goblin leader. And the staff."
msgstr "Descendons. Nous devons trouver le chef gobelin. Et le bâton."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2548
msgid "Wait for us! We are still fighting the machines here!"
msgstr "Attendez-nous ! On se bat encore contre les machines ici !"

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2572
msgid "It looks like the machines around here stopped. This goblin must have has some king of switch on him."
msgstr "On dirait que les machines alentours se sont arrêtées. Ce gobelin devait avoir une sorte d'interrupteur sur lui. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2576
msgid "We should be able to continue without being attacked from behind."
msgstr "On devrait pouvoir continuer sans se faire attaquer par derrière. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2602
msgid "No sign of the staff. The rumor about the goblins having the staff must have been only a rumor."
msgstr "Ancun signe du bâton. La rumeur comme quoi les gobelins avaient le bâton ne devait être qu'une rumeur. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/33_Goblins_Lair.cfg:2606
msgid "We need to start again the investigation."
msgstr "On doit recommencer les recherches de zéro."

#. [scenario], id=34_Hive
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:4
msgid "Hive"
msgstr "La Ruche"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:907
msgid "There are a lot of Gobots here. We must be getting close to the goblin leader."
msgstr "Il y a beaucoup de Gobots ici. On doit être proche du chef gobelin. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:911
msgid "From what we know, if we find him, we find the sceptre. Let's start searching."
msgstr "Pour ce que j'en sais, si on le trouve, on trouve le sceptre. Cherchons. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:941
msgid "It looks like it stopped the leak that was spitting fire from the wall."
msgstr "Il semblerait que cela ait arrêté la fuite qui crachait du feu depuis le mur."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:953
msgid "There's a weird-looking borb here. Should I touch it?"
msgstr "Il y a une drôle d'orbe ici. Je la touche ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1008
msgid "It looks like it stopped the leaks that were spitting fire in the room."
msgstr "Il semblerait que cela ait stoppé la fuite qui crachait du feu dans la pièce."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1041
msgid "The fire caused by the leaks is back."
msgstr "Le feu cause par la fuite est revenu. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1515
msgid "That part of the tunnel looks abandoned."
msgstr "Cette partie des tunnels semble abandonnée. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1641
msgid "Isn't that one of those dwarvish teleporter?"
msgstr "N'est-ce pas l'un de ces téléporteurs nains ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1645
msgid ""
"I'm not even angry. \n"
"I'm being so sincere right now. \n"
"Even though it breaks my heart. \n"
"I'll kill them. \n"
"And tear them to pieces. \n"
"And throw every piece into a fire."
msgstr ""
"Je ne suis pas fâchée. \n"
"Je vous le dis en toute sincérité. \n"
"Bien qu'ils m'aient brisé le cœur. \n"
"Je vais les anéantir.\n"
"Et les briser en mille morceaux. \n"
"Et finalement les jeter dans un brasier."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1654
msgid "How did they even manage to bring it here? It even seems to work. Or at least it's glowing."
msgstr "Comment ils ont fait pour les apporter là ?On dirait même qu'elle fonctionne. Enfin, en tout cas elle brille."

#. [message]
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1658
msgid "You all don't realize. It should not even be possible. One should not be able to move those runes without breaking them or the spell. That's not how magic works."
msgstr "Vous ne vous rendez pas compte. Ce ne devrait même pas être possible. Il ne devrait pas être possible de déplacer ces runes sans les briser ou briser le sort. Ce n'est pas ainsi que la magie fonctionne."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1662
msgid "I mean, it's not like if goblins were well known for using things that can malfunction or explode anytime, right?"
msgstr "Oui, enfin, ce n'est pas comme si les gobelins étaient connus pour utiliser des choses qui peuvent dysfonctionner ou exploser à n'importe quelle moment, n'est-ce pas ?"

#. [message], speaker=Fe
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1709
msgid "Cursed orcs! Cursed invaders!"
msgstr "Maudits orcs ! Maudits envahisseurs !"

#. [message], speaker=Fe
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1713
msgid "Everything rampaged! Fe’s hordes destroyed! "
msgstr "Tout détruit ! Hordes de Fe détruites !"

#. [message], speaker=Fe
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1724
msgid "Ock not have magical staff! Stupid human mage not have staff! "
msgstr "Ock pas avoir bâton magique ! Stupide mage humain pas avoir bâton magique ! "

#. [message], speaker=Fe
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1770
msgid "Protection staff ours! Goblins! You all pay!"
msgstr "Bâton de protection à nous ! Gobelins ! Vous tous payer ! "

#. [message], speaker=Fe
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1793
msgid "Me lose but no problem! Ancient evil and humans fight now!"
msgstr "Moi perdu mais pas problème ! Ancient mal et humains se battre maintenant ! "

#. [message], speaker=Fe
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1797
msgid "Goblins look, laugh and take what’s left! Hahaha!"
msgstr "Gobelins regarder, rire et prendre quoi rester ! Hahaha !"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1820
msgid "There is some kind of force field preventing me from getting closer to the sceptre."
msgstr "Il  y a une sorte de champ de force qui m'empêche de m'approcher du sceptre."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1841
msgid "Here it is. The staff of protection."
msgstr "Le voilà. Le bâton de protection."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1849
msgid "It seems like removing it from its base shut down the complex. At least we won't have to fight those metal things anymore."
msgstr "Il semblerait que l'avoir retiré de sa base ai éteint le complexe. Au moins, nous n'aurons plus à combattre ces choses en métal. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1853
msgid "Hurrah! We have saved Idaamub!"
msgstr "Houra ! Nous avons sauvé Idaamub ! "

#. [message]
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1868
msgid "Not so fast young man. I am afraid this goblin gave us dark news."
msgstr "Pas si vite, jeune homme. J'ai bien peur que ce gobelin ne nous ait donné de sombres nouvelles. "

#. [message]
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1872
msgid "I would seem that the Ocks have survived and are trying once again to destroy Idaamub."
msgstr "Il semblerait que les Ocks aient survécu et qu'ils tentent une fois encore de détruire Idaamub. "

#. [message]
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1876
msgid "We need to get to the capital and warn the king before it is too late. Our journey has not come to its end yet."
msgstr "Nous devons aller à la capitale et prévenir le roi avant qu'il ne soit trop tard. Notre voyage n'est pas encore terminé. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter4/34_Hive.cfg:1948
msgid "It is so frustrating. I feel we are close to finding the sceptre, but these goblins and their machines won't allow us to get it back."
msgstr "C'est tellement frustrant. Je sens qu'on est prêt du sceptre, mais ces gobelins et leurs machines nous empêchent de le récuperer. "

#. [scenario], id=35_Scavengers_Trading_Post
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:4
msgid "Scavenger's Trading Post"
msgstr "Le Comptoir Commercial du Récupérateur"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:45
msgid "Find out where you are"
msgstr "Trouver où vous êtes"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:55
msgid "Go down the old temple road to Oof foretress."
msgstr "Descendre la vieille route du temple jusqu'à la forteresse d'Oof"

#. [side], type=Foul Dark Wose LoI
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:97
msgid "Dark Woses"
msgstr "Woses Noirs"

#. [side], type=Pikeman
#. [side], type=Bay Horse
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:641
#: Legends_of_Idaamub/scenarios/chapter5/35b_Flooded_Tunnels.cfg:813
msgid "Humans"
msgstr "Humains"

#. [unit], id=trader, type=Rogue
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:661
#: Legends_of_Idaamub/scenarios/chapter5/35b_Flooded_Tunnels.cfg:2180
#: Legends_of_Idaamub/scenarios/chapter5/35b_Flooded_Tunnels.cfg:2388
#: Legends_of_Idaamub/scenarios/chapter5/35b_Flooded_Tunnels.cfg:2608
#: Legends_of_Idaamub/scenarios/chapter5/35b_Flooded_Tunnels.cfg:2812
msgid "Oddaty, the Scavenger"
msgstr "Oddaty, le Récupérateur"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:717
msgid "The elevator lead us here. I have no idea were we are. I hope we are no too far from an exit."
msgstr "L'ascenseur nous a amené ici. Je ne sais pas du tout où on est. J'espère qu'on est pas trop loin d'une sortie. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:721
msgid "It looks like there are some machines further, but they don't seem to move. They probably got disabled with the rest of the complex."
msgstr "On dirait qu'il y a quelques machines plus loin, mais elles n'ont pas l'air de bouger. Elle ont probablement été désactivées avec le reste du complexe."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:730
msgid "I gonna smash'em."
msgstr "J'vais les démolir."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:795
msgid "There seem to be a lever there. I gonna pull it."
msgstr "Il y a un levier là. Je le tire?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:812
msgid "A huge rock slid and opened a hole in the wall. It seems I found the exit."
msgstr "Un gros rocher a coulissé et a ouvert un trou dans le mur. Il semblerait que j'ai trouvé la sortie. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:832
msgid "Pull it please."
msgstr "Tirez-le, s'il vous plaît. "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:848
msgid "A huge rock slid and opened a hole in the wall."
msgstr "Un gros rocher a coulissé et ouvert un trou dans le mur."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:852
msgid "It seems we found the exit."
msgstr "On dirait qu'on a trouvé la sortie."

#. [message], speaker=Teumiuxe
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:862
msgid "Wait, those are legionaries. Let me talk to them."
msgstr "Attendez, ce sont des légionnaires. Laiseez-moi leur parler. "

#. [message], speaker=Teumiuxe
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:886
msgid "Legionary, report!"
msgstr "Légionnaires, au rapport !"

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:890
msgid "The Great Mage!"
msgstr "Le Grand Mage !"

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:894
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:964
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1026
msgid "By Of’s shield, is the Guardian sending you?"
msgstr "Par le bouclier d'Of, est-ce le Gardien qui vous envoie ?"

#. [message], speaker=Teumiuxe
#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:898
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:968
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1030
msgid "Actually, we are on a mission for the kingdom, but we might be of mutual help."
msgstr "En fait, nous sommes en mission pour le royaume, mais peut-être pouvons nous nous entraider. "

#. [message], speaker=Teumiuxe
#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:902
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:972
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1034
msgid "Tell me, where are we and what are you doing here?"
msgstr "Dites-moi, où somme nous et que faites vous ici ?"

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:906
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:976
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1038
msgid "Unfortunately, we are in the middle of nowhere. Our detachment left Oof fortress to try to get emergency reinforcement from Udxatfe."
msgstr "Malheureusement, nous sommes au milieu de nulle part. Notre détachement a quitté la forteresse d'Oof pour essayer d'obetenir des renforts d'urgence d'Udxatfe."

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:910
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:980
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1042
msgid "Four days ago, a necromancer with terrible powers by the name of Isut appeared and fell onto us, flanked by undead and Dunefolk. The Dunefolk outnumbering us, they blocked access to Idaamub’s castle from the east and we got blocked from both sides."
msgstr "Il y a quatre jours, un nécromancien doté de terribles pouvoir du nom d'Isut est apparu et nous est tombé dessus, flanqué de morts-vivants et d'Ammorites. Les Ammorites étant en supériorité numérique, ils ont bloqués l'accès au château d'Idaamub depuis l'est et nous avons été bloqués des deux côtés."

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:914
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:984
msgid "That is terrible news."
msgstr "Ce sont de terribles nouvelles."

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:918
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:988
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1050
msgid "The six of us left by the old temple road to dodge Isut, but we fell onto one of his tentacle guardians, which did not spare us. We both took refuge here, but it is impossible to bring reinforcement from the legion to captain Soimaql on time."
msgstr "Nous six sommes partis par la vieille route du temple pour contourner Isut, mais nous sommes tombés sur un de ces gardiens à tentacules, qui ne nous a pas épargné. Nous deux nous sommes réfugiés ici, mais impossible de ramener des renforts de la légion au capitaine Soimaql à temps. "

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:922
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:992
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1054
msgid "We might be able to do something about that."
msgstr "Nous devrions pouvoir nous occuper de ça."

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:926
msgid "I know who you are, I think you should be a match for Isut. You could give my comrades the boost they need to stop this monster before he kills us all."
msgstr "Je sais qui vous êtes, je pense que vous devriez pouvoir tenir tête à Isut. Vous pourriez donner à mes camarades le coup de fouet dont ils ont besoin pour stopper ce monstre avant qu'il ne nous tue tous. "

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:930
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1000
msgid "Our course of action is clear."
msgstr "Notre plan est clair."

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:934
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1004
msgid "We need to go down the old temple road to reach Oof's fortress and free it from Isut."
msgstr "Nous devons descendre la vieille route du temple pour rejoindre la forteresse de Oof et la libérer d'Isut."

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:938
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1008
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1066
msgid "We will then join Idaamub's castle to help break the Dunefolk siege."
msgstr "Nous rejoindrons ensuite le château d'Idammub pour aider à briser le siège Dunefolk."

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:942
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1012
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1070
msgid "Once it is done, we will be able to deliver our message to the king."
msgstr "Une fois cela fait, nous pourrons délivrer notre message au roi. "

#. [message], speaker=Teumiuxe
#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:946
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1016
msgid "Stay here to heal your wounds. You will be of no help like that."
msgstr "Restez ici pour soigner vos plaies. Vous ne nous serez d'aucune aide dans cet état. "

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:950
msgid "Sir, yes, Sir!"
msgstr "Oui, monsieur ! "

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:960
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1022
msgid "Excuse me, sir."
msgstr "Excusez-moi, monsieur."

#. [message], speaker=Durissa
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:996
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1058
msgid "I don’t know who you are, but if you’re as competent as you look like, I think you should be a match for Isut. You could give my comrades the boost they need to stop this monster before he kills us all."
msgstr "Je ne sais pas qui vous êtes, mais si vous êtes aussi compétent que vous en avez l'air, je pense que vous pourriez tenir tête à Isut. Vous pourriez donner à mes camarades le coup de fouet dont ils ont besoin pour stopper ce monstre avant qu'il ne nous tue tous. "

#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1046
msgid "That's terrible news."
msgstr "C'est terrible."

#. [message]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1062
msgid "Well, looks like we need to go down the old temple road to reach Oof's fortress and free it from Isut."
msgstr "Bien il semblerait que nous devions descendre la vieille route du temple pour rejoindre la forteresse de Oof et la libérer de la menace d'Isut. "

#. [message], speaker=Alealyan
#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1093
#: Legends_of_Idaamub/scenarios/chapter5/37_Old_Temple.cfg:723
msgid "Those tentacles, those teeth… those flickering lights… and all those dead… why so many dead?"
msgstr "Ces tentacules, ces dents... ces lumières clignotantes... et tous ces morts... pourquoi tant de morts ?"

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1097
msgid "Looks like he lost his mind."
msgstr "Il semblerait qu'il ait perdu l'esprit."

#. [message], speaker=Oboavlidlu
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1111
msgid "Mylord Oddaty and I supplied a group of treasure hunters that were examining the flooded tunnels west. Maybe you are also going in that direction?"
msgstr "Mon seigneur Oddaty et moi-même avons ravitaillé un groupe de chasseurs de trésor qui examinaient les tunnels inondés à l'ouest. Peut-être allez vous également dans cette direction ?"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1115
msgid "I'm sorry but we aren't."
msgstr "Je suis désolé mais non."

#. [message], speaker=Oboavlidlu
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1119
msgid "They have not come for several days. They never talked about leaving."
msgstr "Il ne sont pas revenus depuis plusieurs jours. Il n'ont jamais parlé de partir. "

#. [message], speaker=Oboavlidlu
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1123
msgid "It is always displeasing to lose regular customers, especially when you do not know where they went. If by chance you meet them, tell them we appreciate doing business with them."
msgstr "Il est toujours déplaisant de perdre des clients réguliers, surtout quand vous ne savez pas où ils sont partis. Si par chance vous les rencontrez, dites leur que nous apprécions faire affaire avec eux. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1127
msgid "Well, if we happen to meet them, we will tell them you are looking forward seeing them again."
msgstr "Et bien, si on les croise, on leur dira que vous avez hâte de les revoir. "

#. [message], speaker=Oboavlidlu
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1131
msgid "And if it happens that they… hmm… closed their account, come back to tell us where they are."
msgstr "Et s'il se trouvait qu'ils aient... hmm... clôturé leur compte, revenez nous dire où ils sont. "

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1135
msgid "I am sorry, but, even if we were to visit those tunnels, I do not think we would have the time to come back to you."
msgstr "Je suis désolé mais, même si on allait visiter ces tunnels, je ne crois pas qu'on aurait le temps de revenir vous voir. "

#. [message], speaker=Oboavlidlu
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1139
msgid "You would not regret it, I promise. In these difficult times, it would be regrettable to lose their… support."
msgstr "Vous ne le regretteriez pas, je vous le promets. En ces temps difficiles, il serait regrettable de perdre leur... support."

#. [message], speaker=Oboavlidlu
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1143
msgid "Were I to learn that you go into the tunnels, I would wait for you at their entrance; that way you will not have to come back here."
msgstr "Si je venais à apprendre que vous allez dans les tunnels, je vous attendrais à leur entrée; ainsi vous n'auriez pas à revenir ici."

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1159
msgid "Come in, come in! Hmm… you do not seem move in the best circles, but one should never under-estimate the lower classes…"
msgstr "Entrez, entrez ! Hmm... vous ne semblez pas graviter dans les meilleurs cercles, mais on ne devrait jamais sous-estimer les classes inférieures..."

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1163
msgid "My assistant and I have found these items on a group of mages on the temple road. Some of these items might interest you, but we have not yet got them rid of their… unpleasant smell."
msgstr "Mon assistant et moi avons trouvé ces objets sur un groupe de mages qur la route du temple. Certains de ces objets vous intéresseront peut-être, bien que je n'ai pas encore réussi à les débarasser de leur... déplaisante odeur."

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1167
msgid "But it should not disturb someone like you, should it?"
msgstr "Mais cela ne devrait pas perturber quelqu'un comme vous, n'est-ce pas ?"

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1208
msgid "What can Oddaty the Scavenger do for you today?"
msgstr "Que peut faire Oddaty le récupérateur pour vous aujourd'hui ?"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1451
#: Legends_of_Idaamub/utils/item_list.cfg:14064
msgid "Avenging blade-staff of revival"
msgstr "Bâton-lame vengeur de regain"

#. [message], speaker=trader
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1452
msgid "Staff of awareness"
msgstr "Bâton de conscience"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1453
#: Legends_of_Idaamub/utils/item_list.cfg:14105
msgid "Avenging staff of focus"
msgstr "Bâton vengeur de concentration"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1454
#: Legends_of_Idaamub/utils/item_list.cfg:14122
msgid "Avenging thorny blade-staff"
msgstr "Bâton-lame vengeur épineux"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1481
#: Legends_of_Idaamub/utils/item_list.cfg:14217
msgid "Avenging long reinforced bow of the fox"
msgstr "Arc long renforcé vengeur du renard"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1482
#: Legends_of_Idaamub/utils/item_list.cfg:14241
msgid "Avenging war bow of massacre"
msgstr "Arc de guerre vengeur de massacre"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1483
#: Legends_of_Idaamub/utils/item_list.cfg:14258
msgid "Long reinforced slippery bow of revival"
msgstr "Arc long renforcé glissant de regain"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1484
#: Legends_of_Idaamub/utils/item_list.cfg:14280
msgid "Long reinforced slippery bow of midnight"
msgstr "Arc long renforcé glissant de minuit"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1485
#: Legends_of_Idaamub/utils/item_list.cfg:14297
msgid "Slippery war bow of disease"
msgstr "Arc de guerre glissant de maladie"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1512
#: Legends_of_Idaamub/utils/item_list.cfg:13932
msgid "Avenging longsword of vivacity"
msgstr "Epée longue vengeuse de vivacité"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1513
#: Legends_of_Idaamub/utils/item_list.cfg:13950
msgid "Ripper longsword of vivacity"
msgstr "Epée longue éventreuse de vivacité"

#. [message], speaker=trader
#. [object]
#: Legends_of_Idaamub/scenarios/chapter5/35_Scavengers_Trading_Post.cfg:1514
#: Legends_of_Idaamub/utils/item_list.cfg:13965
msgid "Avenging steel thorny sword"
msgstr "Epée en acier vengeuse épineuse"

