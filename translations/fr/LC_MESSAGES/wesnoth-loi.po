#. [scenario], id=12_Mine_Rats
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:4
msgid "Mine Rats"
msgstr "Rats de Mines"

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:35
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:41
msgid "Find a way to go to the lower level of the mine."
msgstr "Trouver un chemin jusqu'au niveau inférieur de la mine."

#. [objective], condition=win
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:46
msgid "Find and destroy the rat nest before going down."
msgstr "Trouver et détruire le nid de rat avant de descendre."

#. [side], type=Direrat LoI
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:481
msgid "Rats"
msgstr "Rats"

#. [side], type=Stone Golem
#. [side], type=Giant Scorpion
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:501
#: Legends_of_Idaamub/scenarios/chapter3/19b_Northern_Lights.cfg:236
msgid "Scorpions"
msgstr "Scorpions"

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:564
msgid "Let's recap. Our main mission is still to carry the message to Udxatfe. "
msgstr "On récapitule. Notre mission principale est d'apporter le message à Udxatfe."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:574
msgid "If we can find him, it would be useful to also save Amin's brother, Hufifa, as he probably has information about what is happening."
msgstr "Si on peut le trouver, ça serait utile de sauver également le frère d'Amin, Hufifa, vu qu'il a probablement des informations sur ce qu'il se passe."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:578
msgid "This should be our main mission."
msgstr "Ce devrait être notre mission principale."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:582
msgid "We will do what we can to save your brother, but the fate of the world might be at play here."
msgstr "On fera ce qu'on peut pour sauver votre frère, mais le destin du monde pourrait être en jeu là."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:586
msgid "Which way is the elevator to the lower level?"
msgstr "L'ascenseur pour le niveau inférieur est par où ??"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:590
msgid "*grumpy* It's north then west."
msgstr "<i>grognon</i> Il faut aller au nord puis à l'ouest."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:596
msgid "If we can find him, it would be useful to also save Hufifa, as he probably has information about what is happening."
msgstr "Si on peut le trouver, ça serait utile de sauver également Hufifa, vu qu'il a probablement des informations sur ce qu'il se passe."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:629
msgid "Giant rats. The mine is swarming with them."
msgstr "Des rats géants. La mine en est infestée."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:633
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:651
msgid "We tried to get rid of them, but we couldn't find the nest."
msgstr "Nous avons essayé de nous en débarrasser, mais nous 'avons pas réussi à trouver le nid."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:637
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:655
msgid "If we can find and destroy it, it would prevent them from attacking us from behind."
msgstr "Si nous pouvons le trouver et le détruire, cela éviterait qu'ils nous attaquent par derrière."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:643
msgid "What's this? It looks like a rat, but far bigger."
msgstr "Qu'est-ce que c'est ? Ça ressemble à un rat mais en beaucoup plus gros."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:647
msgid "Those are giant rats. The mine is swarming with them."
msgstr "Ce sont des rats géants. La mine en est infestée."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:683
msgid "This is the ugliest rat I have ever seen. It must be their king or something like that."
msgstr "C'est le rat le plus moche que je n'ai jamais vu. Ce doit être leur roi ou quelque chose comme ça."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:716
msgid "Here are the scorpions I was talking about."
msgstr "Voilà les scorpions dont je parlais."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:722
msgid "So those are the famous scorpions Amin told us about."
msgstr "Voilà donc les fameux scorpions dont nous parlais Amin."

#. [message], speaker=second_unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:730
msgid "Come on! Scorpions?! What else?! Flying tigers?!"
msgstr "Sans blague ! Des scorpions ?! Quoi d'autre encore ?! Des tigres volants ?!"

#. [message], speaker=Lujeje
#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:761
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:804
msgid "Look other there. It's a stone golem. A pile of rocks moved by magic."
msgstr "Regardez par ici. C'est un golem de pierre. Une pile de cailloux animée par magie."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:765
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:852
msgid "It is probably natural."
msgstr "C'est probablement un phénomène naturel."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:769
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:812
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:856
msgid "The orcs couldn't have made it. The creation of a golem requires far more magic than animating skeletons."
msgstr "Les orcs n'ont pas pu le fabriquer. La création d'un golem requiert bien plus de magie qu'animer des squelettes. "

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:779
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:816
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:866
msgid "You're only half right."
msgstr "Vous n'avez qu'à moitié raison."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:783
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:820
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:870
msgid "The orcs haven't made them, but it is not natural either. They were brought here by the demons and as they can't die, they are still roaming the place."
msgstr "Les orcs ne les ont fabriqués, mais ils ne sont pas naturels non plus. Ils ont été apportés ici par les démons et comme ils ne peuvent pas mourir, ils se promènent toujours dans le coin."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:787
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:824
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:874
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:900
msgid "We discover one of them from time to time while mining. They are strong against axes, less against hammers."
msgstr "On en découvre un de temps en temps en minant. Ils sont forts contre les haches, mais moins contre les marteaux."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:791
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:828
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:878
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:904
msgid "Are there other creatures we should worry about?"
msgstr "Il y a d'autres créatures dont on devrait s'inquiéter ?"

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:795
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:832
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:882
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:908
msgid "There are some more, like scorpions or shadows, so we must be careful."
msgstr "Il y en a quelques autres, comme les scorpions ou les ombres, alors nous devrons faire attention."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:808
msgid "Interesting. It is probably natural."
msgstr "Intéressant. C'est probablement un phénomène naturel."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:838
msgid "What's this? It looks like a moving pile of rocks."
msgstr "Qu'est-ce que c'est ? On dirait une pile de cailloux qui bouge."

#. [message], speaker=Lujeje
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:848
msgid "It's a stone golem. A pile of rocks moved by magic."
msgstr "C'est un golem de pierre. Une pile de cailloux animée par magie."

#. [message], speaker=Amin
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:896
msgid "Those are stone golems. They were brought here by the demons and as they can't die, they are still roaming the place."
msgstr "Ce sont des golems de pierre. Ils ont été apportés ici par les démons et comme ils ne peuvent pas mourir, ils se promènent encore dans le coin."

#. [message], speaker=Io
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:914
msgid "No idea."
msgstr "Aucune idée."

#. [message], speaker=unit
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:944
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1004
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1064
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1124
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1184
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1244
#: Legends_of_Idaamub/scenarios/chapter2/13_Miners_life.cfg:759
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1101
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1160
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1219
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1277
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1324
#: Legends_of_Idaamub/scenarios/chapter2/14_Mine_maze.cfg:1452
#: Legends_of_Idaamub/scenarios/chapter2/14b_Down_the_Elevator.cfg:146
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:551
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:610
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:669
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:736
#: Legends_of_Idaamub/scenarios/chapter2/15_Ups_and_Downs.cfg:813
msgid "There's a barrel full of powder. Should I light it up?"
msgstr "Il y a un baril de poudre. Je l'allume ?"

#. [option]
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:946
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1006
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1066
#: Legends_of_Idaamub/scenarios/chapter2/12_Mine_Rats.cfg:1126
